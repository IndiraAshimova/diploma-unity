--- !u!114 &422028720
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 422028718}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 157a3517668cfd940b7f9d85d2eaae44, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    lines:
    - sentence: "\u041C\u0456\u0440\u0436\u0430\u049B\u044B\u043F \u0414\u0443\u043B\u0430\u0442\u04B1\u043B\u044B
        (1885\u20131935) - \u0410\u043B\u0430\u0448 \u049B\u043E\u0437\u0493\u0430\u043B\u044B\u0441\u044B\u043D\u044B\u04A3
        \u043A\u04E9\u0440\u043D\u0435\u043A\u0442\u0456 \u049B\u0430\u0439\u0440\u0430\u0442\u043A\u0435\u0440\u0456,
        \u0430\u049B\u044B\u043D,  \u0436\u0430\u0437\u0443\u0448\u044B \u0436\u0259\u043D\u0435
        \u043F\u0443\u0431\u043B\u0438\u0446\u0438\u0441\u0442. \u041E\u043B - \u049B\u0430\u0437\u0430\u049B
        \u0437\u0438\u044F\u043B\u044B\u043B\u0430\u0440\u044B\u043D\u044B\u04A3
        \u0456\u0448\u0456\u043D\u0434\u0435\u0433\u0456 \u0435\u04A3 \u0431\u0430\u0442\u044B\u043B
        \u049B\u0430\u043B\u0430\u043C\u0433\u0435\u0440\u043B\u0435\u0440\u0434\u0456\u04A3
        \u0431\u0456\u0440\u0456.  \u041E\u043D\u044B\u04A3 \u04E9\u043C\u0456\u0440\u0456
        \xAB\u041E\u044F\u043D, \u049A\u0430\u0437\u0430\u049B!\xBB \u04B1\u0440\u0430\u043D\u044B\u043C\u0435\u043D
        \u04E9\u0442\u0442\u0456. 1909 \u0436\u044B\u043B\u044B \u0436\u0430\u0440\u044B\u049B
        \u043A\u04E9\u0440\u0433\u0435\u043D \u0430\u0442\u0442\u0430\u0441 \u043A\u0456\u0442\u0430\u0431\u044B
        \u04AF\u0448\u0456\u043D  \u043F\u0430\u0442\u0448\u0430 \u04AF\u043A\u0456\u043C\u0435\u0442\u0456
        \u0442\u0430\u0440\u0430\u043F\u044B\u043D\u0430\u043D \u049B\u0443\u0493\u044B\u043D\u0493\u0430
        \u04B1\u0448\u044B\u0440\u0430\u043F, \u04E9\u043C\u0456\u0440\u0456\u043D\u0456\u04A3
        \u0441\u043E\u04A3\u044B\u043D\u0430 \u0434\u0435\u0439\u0456\u043D \u04B1\u043B\u0442
        \u0431\u043E\u0441\u0442\u0430\u043D\u0434\u044B\u0493\u044B \u04AF\u0448\u0456\u043D 
        \u043A\u04AF\u0440\u0435\u0441\u0442\u0456. \u041E\u043B \u0436\u0430\u0439
        \u0493\u0430\u043D\u0430 \u049B\u0430\u043B\u0430\u043C\u0433\u0435\u0440
        \u0435\u043C\u0435\u0441, \u04B1\u043B\u0442\u0442\u044B\u04A3 \u0441\u0430\u043D\u0430\u0441\u044B\u043D
        \u043E\u044F\u0442\u049B\u0430\u043D \u0440\u0443\u0445\u0430\u043D\u0438
        \u043A\u04E9\u0448\u0431\u0430\u0441\u0448\u044B \u0431\u043E\u043B\u0434\u044B. "
      speakerName: 
      characterSprite: {fileID: 0}
      side: 0
  storyManager: {fileID: 461008547}
