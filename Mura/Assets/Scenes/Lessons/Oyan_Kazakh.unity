--- !u!114 &579244822
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 579244820}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 157a3517668cfd940b7f9d85d2eaae44, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    lines:
    - sentence: "1909 \u0436\u044B\u043B. \u049A\u0430\u0437\u0430\u049B \u0434\u0430\u043B\u0430\u0441\u044B
        - \u04AF\u043B\u043A\u0435\u043D \u04E9\u0437\u0433\u0435\u0440\u0456\u0441\u0442\u0435\u0440
        \u049B\u0430\u0440\u0441\u0430\u04A3\u044B\u043D\u0434\u0430\u0493\u044B
        \u0434\u0435\u0440\u0442\u0442\u0456 \u043C\u0435\u043A\u0435\u043D. \u0425\u0430\u043B\u044B\u049B
        \u0435\u043A\u0456 \u043E\u0442\u0442\u044B\u04A3  \u043E\u0440\u0442\u0430\u0441\u044B\u043D\u0434\u0430
        \u049B\u0430\u043B\u0434\u044B: \u0431\u0456\u0440\u0456 - \u043F\u0430\u0442\u0448\u0430\u043D\u044B\u04A3
        \u043E\u0442\u0430\u0440\u043B\u0430\u0443 \u0441\u0430\u044F\u0441\u0430\u0442\u044B
        \u043C\u0435\u043D \u0436\u0435\u0440\u0456\u043D \u0442\u0430\u0440\u0442\u044B\u043F
        \u0430\u043B\u0443\u044B, \u0435\u043A\u0456\u043D\u0448\u0456\u0441\u0456
        - \u04E9\u0437  \u0456\u0448\u0456\u043D\u0434\u0435\u0433\u0456 \u043D\u0430\u0434\u0430\u043D\u0434\u044B\u049B
        \u043F\u0435\u043D \u0441\u0430\u0443\u0430\u0442\u0441\u044B\u0437\u0434\u044B\u049B.
        \u041A\u04E9\u0448\u043F\u0435\u043B\u0456 \u04E9\u0440\u043A\u0435\u043D\u0438\u0435\u0442
        \u04E9\u0448\u0456\u043F, \u0436\u0430\u04A3\u0430 \u0437\u0430\u043C\u0430\u043D\u043D\u044B\u04A3
        \u0442\u0430\u043B\u0430\u0431\u044B\u043D\u0430  \u0456\u043B\u0435\u0441\u0435
        \u0430\u043B\u043C\u0430\u0439, \u0445\u0430\u043B\u044B\u049B \xAB\u04B1\u0439\u049B\u044B\u0434\u0430\xBB
        \u0436\u0430\u0442\u0442\u044B. \u0415\u043B\u0434\u0456\u04A3 \u0431\u043E\u043B\u0430\u0448\u0430\u0493\u044B
        \u0431\u04B1\u043B\u044B\u04A3\u0493\u044B\u0440, \u0430\u043B \xAB\u049A\u0430\u0437\u0430\u049B\xBB
        \u0434\u0435\u0433\u0435\u043D \u0430\u0442 \u049B\u0430\u043D\u0430  \u049B\u0430\u043B\u0493\u0430\u043D
        \u0435\u0434\u0456\u2026"
      speakerName: 
      characterSprite: {fileID: 0}
      side: 0
  storyManager: {fileID: 1553432469}
