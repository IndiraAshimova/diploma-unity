--- !u!114 &1021527573
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1021527571}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 157a3517668cfd940b7f9d85d2eaae44, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    lines:
    - sentence: "\\n\u0417\u0430\u0440 \u0437\u0430\u043C\u0430\u043D, \u0437\u0430\u0440
        \u0437\u0430\u043C\u0430\u043D,  \\n\u0417\u0430\u0440\u043B\u0430\u043F
        \u04E9\u0442\u043A\u0435\u043D \u0431\u0456\u0440 \u0437\u0430\u043C\u0430\u043D. 
        \\n\u0421\u04E9\u0437\u0434\u0456\u04A3 \u0431\u0430\u0441\u044B - \u0431\u0438\u0441\u043C\u0456\u043B\u043B\u0430, 
        \\n\u0411\u0456\u0437 \u0430\u0439\u0442\u0430\u043B\u044B\u049B, \u0441\u0456\u0437
        \u0442\u044B\u04A3\u0434\u0430  \\n\u041C\u04B1\u0441\u044B\u043B\u043C\u0430\u043D\u043D\u044B\u04A3
        \u0442\u0430\u0440\u0438\u0445\u044B\u043D:  \\n\u0422\u04E9\u0440\u0442
        \u0430\u044F\u049B\u0442\u044B \u0445\u0430\u0439\u0443\u0430\u043D -  \\n\u0411\u04B1
        \u0434\u04AF\u043D\u0438\u0435\u043D\u0456\u04A3 \u0436\u0430\u0440\u044B\u0493\u044B. 
        \\n\u0411\u0430\u0493\u0430\u0441\u044B \u043A\u0435\u0442\u043A\u0435\u043D
        \u0436\u0456\u0433\u0456\u0442\u0442\u0456\u04A3  \\n\u0411\u0435\u0442\u0456\u043D\u0435\u043D
        \u0430\u043B\u0430\u0440 \u0437\u0430\u0439\u044B\u0431\u044B.  \\n\u0411\u0456\u0440
        \u0430\u043B\u043B\u0430\u0434\u0430\u043D \u0431\u0430\u0441\u049B\u0430\u043D\u044B\u04A3 
        \\n\u041A\u04E9\u043F\u0442\u0456 \u049B\u044B\u043B\u0493\u0430\u043D \u0430\u0439\u044B\u0431\u044B. 
        \\n\u041A\u0435\u0441\u0430\u043F\u0430\u0442\u0442\u044B\u04A3 \u043A\u0435\u0441\u0456\u0440\u0456 
        \\n\u041A\u0435\u043B\u0435 \u043C\u0435 \u0434\u0435\u043F \u043A\u0435\u0440\u0442
        \u0431\u0430\u0441\u049B\u0430,  \\n\u0421\u043E\u043B \u0441\u0435\u0431\u0435\u043F\u0442\u0435\u043D
        \u049B\u043E\u0440\u049B\u0430\u043C\u044B\u043D! "
      speakerName: 
      characterSprite: {fileID: 0}
      side: 0
    - sentence: "\\n\u018F\u0443\u0435\u043B\u0433\u0456 \u049B\u043E\u0440\u043B\u0430\u0440
        \u0437\u043E\u0440 \u0431\u043E\u043B\u0434\u044B,  \\n\u0421\u043E\u043D\u0434\u0430\u0439
        \u0437\u043E\u0440\u043B\u0430\u0440 \u049B\u043E\u0440 \u0431\u043E\u043B\u0434\u044B, 
        \\n\u018F\u0443\u0435\u043B\u0433\u0456 \u0431\u0430\u0440\u043B\u0430\u0440
        \u0436\u043E\u049B \u0431\u043E\u043B\u0434\u044B,  \\n\u0421\u043E\u043D\u0434\u0430\u0439
        \u0436\u043E\u049B\u0442\u0430\u0440 \u0442\u043E\u049B \u0431\u043E\u043B\u0434\u044B, 
        \\n\u0416\u04E9\u043D \u0431\u0456\u043B\u043C\u0435\u0433\u0435\u043D \u0436\u0430\u043C\u0430\u043D\u0434\u0430\u0440 
        \\n\u0415\u043B \u0431\u0438\u043B\u0435\u0433\u0435\u043D \u0431\u0435\u043A
        \u0431\u043E\u043B\u0434\u044B,  \\n\u041A\u04E9\u0442\u0435\u0440\u0435
        \u0430\u043B\u043C\u0430\u0439 \u0431\u0438\u043B\u0456\u0433\u0456\u043D, 
        \\n\u04B0\u043B\u0430\u0441\u049B\u0430\u043D \u04AF\u043B\u043A\u0435\u043D
        \u043A\u0435\u043A \u0431\u043E\u043B\u0434\u044B,  \\n\u041D\u0438\u0435\u0442\u0456\u043D\u0435
        \u049B\u0430\u0437\u0430\u049B\u0442\u044B\u04A3  \\n\u0422\u044B\u043C -
        \u0430\u049B \u0442\u0259\u0443\u0456\u0440 \u0435\u043F \u0431\u043E\u043B\u0434\u044B
        -  \\n\u0417\u0430\u043C\u0430\u043D\u0430\u049B\u044B\u0440 \u0431\u043E\u043B\u0430\u0440
        \u0434\u0435\u043F,  \\n\u0421\u043E\u043B \u0441\u0435\u0431\u0435\u043F\u0442\u0435\u043D
        \u049B\u043E\u0440\u049B\u0430\u043C\u044B\u043D! "
      speakerName: 
      characterSprite: {fileID: 0}
      side: 0
    - sentence: "\\n\u049A\u044B\u0441 \u043A\u04E9\u0431\u0435\u0439\u0434\u0456
        - \u0436\u0430\u0437 \u0430\u0437 \u0431\u043E\u043F,  \\n\u0411\u0430\u0439
        \u0442\u0430\u0443\u0441\u044B\u043B\u0434\u044B - \u043C\u0430\u043B \u0430\u0437
        \u0431\u043E\u043F,  \\n\u0410\u0493\u0430\u0439\u044B\u043D\u044B \u043A\u04E9\u0440\u0435
        \u0430\u043B\u043C\u0430\u0439,  \\n\u0410\u0442\u0430\u0493\u0430 \u0431\u0430\u043B\u0430
        \u0430\u0440\u0430\u0437 \u0431\u043E\u043F.  \\n\u018F\u0440 \u043D\u0259\u0440\u0441\u0435\u043D\u0456\u04A3
        \u0431\u043E\u043B\u0436\u0430\u043B\u044B  \\n\u041A\u0435\u043B\u0435 \u0436\u0430\u0442\u044B\u0440
        \u0436\u0430\u049B\u044B\u043D\u0434\u0430\u043F.  \\n\u0410\u0493\u0430\u0448\u0442\u044B
        \u0442\u0430\u0443\u0493\u0430 \u04AF\u0439 \u0441\u0430\u043B\u044B\u043F, 
        \\n\u0410\u043B\u0434\u044B \u043A\u0259\u043F\u0456\u0440 \u0430\u049B\u044B\u043D\u0434\u0430, 
        \\n\u0415\u043B\u0434\u0456 \u0435\u0440\u043A\u0456\u043D\u0435 \u049B\u043E\u0439\u043C\u0430\u0434\u044B 
        \\n\u0411\u0443\u044B\u0440\u0448\u044B\u043D\u0434\u0430\u0439 \u0442\u0430\u049B\u044B\u043C\u0434\u0430\u043F. 
        \\n\u0414\u0443\u0430\u043D \u0431\u0430\u0441\u044B, \u0431\u043E\u043B\u044B\u0441
        \u0442\u04B1\u0440  \\n\u041A\u0259\u043F\u0456\u0440\u0434\u0456\u04A3 \u0441\u04E9\u0437\u0456\u043D
        \u043C\u0430\u049B\u04B1\u043B\u0434\u0430\u043F,  \\n\u0411\u0435\u0439\u0448\u0430\u0440\u0430\u043D\u044B\u04A3
        \u043F\u04B1\u043B\u044B \u0436\u043E\u049B,  \\n\u049A\u043E\u0440\u044B\u049B\u049B\u0430\u043D\u043D\u0430\u043D
        \u049B\u0430\u049B\u044B\u043B\u0434\u0430\u043F.  \\n\u0416\u0430\u0440\u044B\u0441\u049B\u0430
        \u043A\u0456\u0440\u0433\u0435\u043D \u0436\u0430\u049B\u0441\u044B\u043B\u0430\u0440, 
        \\n\u0410\u0448\u0430 \u0430\u043B\u043C\u0430\u0441\u0441\u044B\u04A3 \u043A\u04E9\u0437\u0456\u04A3
        \u0434\u0435\u043F,  \\n\u0421\u043E\u043B \u0441\u0435\u0431\u0435\u043F\u0442\u0456
        \u049B\u043E\u0440\u049B\u0430\u043C\u044B\u043D!"
      speakerName: 
      characterSprite: {fileID: 0}
      side: 0
  storyManager: {fileID: 535694282}
