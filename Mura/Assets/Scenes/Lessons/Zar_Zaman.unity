--- !u!114 &1053355806
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1053355804}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 157a3517668cfd940b7f9d85d2eaae44, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    lines:
    - sentence: "\u049A\u0430\u0437\u0430\u049B \u0434\u0430\u043B\u0430\u0441\u044B
        \u04AF\u0448\u0456\u043D \u043A\u04E9\u0448\u0456-\u049B\u043E\u043D - \u0436\u0430\u0439
        \u0493\u0430\u043D\u0430 \u043E\u0440\u044B\u043D \u0430\u0443\u044B\u0441\u0442\u044B\u0440\u0443
        \u0435\u043C\u0435\u0441, \u0442\u0430\u0431\u0438\u0493\u0430\u0442\u043F\u0435\u043D
        \u04AF\u0439\u043B\u0435\u0441\u043A\u0435\u043D \u0434\u0435\u0440\u0431\u0435\u0441 
        \u04E9\u0440\u043A\u0435\u043D\u0438\u0435\u0442\u0442\u0456\u04A3 \u0442\u0456\u0440\u0448\u0456\u043B\u0456\u043A
        \u0444\u043E\u0440\u043C\u0430\u0441\u044B \u0435\u0434\u0456. \xAB\u0410\u0442\u0430
        \u049B\u043E\u043D\u044B\u0441 - \u0430\u043B\u0442\u044B\u043D \u0431\u0435\u0441\u0456\u043A\xBB
        \u049B\u0430\u0493\u0438\u0434\u0430\u0441\u044B\u043C\u0435\u043D \u04E9\u043C\u0456\u0440
        \u0441\u04AF\u0440\u0433\u0435\u043D  \u0445\u0430\u043B\u044B\u049B\u0442\u044B\u04A3
        \u04B1\u043B\u0430\u043D-\u0493\u0430\u0439\u044B\u0440 \u0434\u0430\u043B\u0430\u0434\u0430\u0493\u044B
        \u0435\u0440\u043A\u0456\u043D \u0442\u044B\u043D\u044B\u0441\u044B 1867-1868
        \u0436\u044B\u043B\u0434\u0430\u0440\u0434\u0430\u0493\u044B \u043F\u0430\u0442\u0448\u0430 
        \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0441\u044B\u043D\u0430\u043D
        \u043A\u0435\u0439\u0456\u043D \u0442\u04B1\u0441\u0430\u0443\u043B\u0430\u043D\u0434\u044B.
        \u0420\u0435\u0441\u0435\u0439 \u0438\u043C\u043F\u0435\u0440\u0438\u044F\u0441\u044B
        \u049B\u0430\u0437\u0430\u049B \u0436\u0435\u0440\u0456\u043D \xAB\u043C\u0435\u043C\u043B\u0435\u043A\u0435\u0442
        \u043C\u0435\u043D\u0448\u0456\u0433\u0456\xBB \u0434\u0435\u043F  \u0436\u0430\u0440\u0438\u044F\u043B\u0430\u043F,
        \u0259\u043A\u0456\u043C\u0448\u0456\u043B\u0456\u043A \u0448\u0435\u043A\u0430\u0440\u0430\u043B\u0430\u0440
        \u0435\u043D\u0433\u0456\u0437\u0443\u0456 \u0493\u0430\u0441\u044B\u0440\u043B\u0430\u0440
        \u0431\u043E\u0439\u044B \u049B\u0430\u043B\u044B\u043F\u0442\u0430\u0441\u049B\u0430\u043D
        \u044D\u043A\u0437\u043E\u0433\u0435\u043D\u0434\u0456\u043A  \u0448\u0430\u0440\u0443\u0430\u0448\u044B\u043B\u044B\u049B
        \u0436\u04AF\u0439\u0435\u0441\u0456 \u043C\u0435\u043D \u043A\u04E9\u0448
        \u0436\u043E\u043B\u0434\u0430\u0440\u044B\u043D \u0442\u04AF\u0431\u0435\u0433\u0435\u0439\u043B\u0456
        \u0442\u0430\u043B\u049B\u0430\u043D\u0434\u0430\u0434\u044B."
      speakerName: 
      characterSprite: {fileID: 0}
      side: 0
    - sentence: "\u0411\u04B1\u043B \u0441\u0430\u044F\u0441\u0438 \u04E9\u0437\u0433\u0435\u0440\u0456\u0441
        \u049B\u043E\u0493\u0430\u043C\u0434\u044B\u049B \u043C\u043E\u0440\u0430\u043B\u044C
        \u043C\u0435\u043D \u04B1\u043B\u0442\u0442\u044B\u049B \u049B\u04B1\u043D\u0434\u044B\u043B\u044B\u049B\u0442\u0430\u0440\u0434\u044B\u04A3
        \u0434\u0435\u0433\u0440\u0430\u0434\u0430\u0446\u0438\u044F\u0441\u044B\u043D\u0430
        \u0259\u043A\u0435\u043B\u0434\u0456.  \u0428\u043E\u0440\u0442\u0430\u043D\u0431\u0430\u0439
        \u049A\u0430\u043D\u0430\u0439\u04B1\u043B\u044B \u0431\u0430\u0441\u0442\u0430\u0493\u0430\u043D
        \xAB\u0417\u0430\u0440 \u0437\u0430\u043C\u0430\u043D\xBB \u04E9\u043A\u0456\u043B\u0434\u0435\u0440\u0456
        \u0436\u044B\u0440\u043B\u0430\u0493\u0430\u043D\u0434\u0430\u0439, \u0437\u0430\u043C\u0430\u043D\u043D\u044B\u04A3
        \u0430\u0437\u0443\u044B \u043C\u0430\u043B\u0434\u044B\u04A3  \u0430\u0437\u0430\u044E\u044B\u043D\u0430\u043D
        \u0435\u043C\u0435\u0441, \u0430\u0434\u0430\u043C\u043D\u044B\u04A3 \u0456\u0448\u043A\u0456
        \u0431\u043E\u043B\u043C\u044B\u0441\u044B \u043C\u0435\u043D \u0441\u0430\u043B\u0442\u0442\u044B\u04A3
        \u0431\u04B1\u0437\u044B\u043B\u0443\u044B\u043D\u0430\u043D \u043A\u04E9\u0440\u0456\u043D\u0456\u0441
        \u0442\u0430\u043F\u0442\u044B.  \u0420\u0435\u0444\u043E\u0440\u043C\u0430\u043C\u0435\u043D
        \u043A\u0435\u043B\u0433\u0435\u043D \u0431\u043E\u043B\u044B\u0441\u0442\u044B\u049B
        \u0431\u0430\u0441\u049B\u0430\u0440\u0443 \u0436\u04AF\u0439\u0435\u0441\u0456
        \u0431\u0438\u043B\u0435\u0440 \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u044B\u043D\u044B\u04A3
        \u0259\u0434\u0456\u043B\u0434\u0456\u0433\u0456\u043D  \u043C\u0430\u043D\u0441\u0430\u043F\u049B\u043E\u0440\u043B\u044B\u049B
        \u043F\u0435\u043D \u043F\u0430\u0440\u0430\u049B\u043E\u0440\u043B\u044B\u049B\u049B\u0430
        \u0430\u0439\u044B\u0440\u0431\u0430\u0441\u0442\u0430\u043F, \u0435\u043B
        \u0456\u0448\u0456\u043D\u0435 \u0456\u0440\u0456\u0442\u043A\u0456 \u0441\u0430\u043B\u0434\u044B.
        \u0421\u043E\u043D\u044B\u04A3 \u0441\u0430\u043B\u0434\u0430\u0440\u044B\u043D\u0430\u043D 
        \u0431\u04B1\u0440\u044B\u043D\u0493\u044B \u0431\u0430\u0443\u044B\u0440\u043C\u0430\u043B\u0434\u044B\u049B
        \u043F\u0435\u043D \u0436\u043E\u043C\u0430\u0440\u0442\u0442\u044B\u049B
        \u0436\u043E\u0493\u0430\u043B\u044B\u043F, \u0430\u0493\u0430\u0439\u044B\u043D
        \u0430\u0440\u0430\u0441\u044B\u043D\u0434\u0430 \u0436\u0435\u0440 \u043C\u0435\u043D
        \u0448\u0435\u043D \u04AF\u0448\u0456\u043D  \u0430\u0440\u0430\u0437\u0434\u044B\u049B
        \u0431\u0435\u043B\u0435\u04A3 \u0430\u043B\u0434\u044B. "
      speakerName: 
      characterSprite: {fileID: 0}
      side: 0
    - sentence: "\u041E\u0441\u044B\u043B\u0430\u0439\u0448\u0430, \u0434\u0259\u0441\u0442\u04AF\u0440\u043B\u0456
        \u043A\u04E9\u0448\u043F\u0435\u043B\u0456 \u04E9\u0440\u043A\u0435\u043D\u0438\u0435\u0442
        \u0442\u0430\u0440\u0438\u0445 \u0441\u0430\u0445\u043D\u0430\u0441\u044B\u043D\u0430\u043D
        \u043A\u04AF\u0448\u043F\u0435\u043D \u044B\u0493\u044B\u0441\u0442\u044B\u0440\u044B\u043B\u044B\u043F,
        \u043E\u043D\u044B\u04A3  \u043E\u0440\u043D\u044B\u043D \u043E\u0442\u0430\u0440\u043B\u0430\u0443\u0434\u044B\u04A3
        \u049B\u0430\u0442\u0430\u043B \u0437\u0430\u04A3\u0434\u0430\u0440\u044B
        \u0431\u0430\u0441\u0442\u044B. \u041A\u04E9\u0448 \u0436\u043E\u043B\u0434\u0430\u0440\u044B\u043D\u044B\u04A3
        \u0436\u0430\u0431\u044B\u043B\u0443\u044B \u043C\u0435\u043D \xAB\u0435\u0440\u0443\u043B\u0456\u043A\xBB
        \u0441\u0435\u043A\u0456\u043B\u0434\u0456  \u0438\u0433\u0456 \u0434\u0259\u0441\u0442\u04AF\u0440\u043B\u0435\u0440\u0434\u0456\u04A3
        \u04B1\u043C\u044B\u0442\u044B\u043B\u0443\u044B - \u049B\u0430\u0437\u0430\u049B\u0442\u044B\u04A3
        \u04B1\u043B\u0442\u0442\u044B\u049B \u043A\u043E\u0434\u044B\u043D\u0430
        \u0436\u0430\u0441\u0430\u043B\u0493\u0430\u043D \u0430\u043B\u0493\u0430\u0448\u049B\u044B
        \u0436\u04AF\u0439\u0435\u043B\u0456 \u0441\u043E\u049B\u049B\u044B  \u0431\u043E\u043B\u0434\u044B.
        \u0411\u04B1\u043B \u043A\u0435\u0437\u0435\u04A3 \u0445\u0430\u043B\u044B\u049B\u0442\u044B\u04A3
        \u0436\u0430\u0434\u044B\u043D\u0434\u0430 \u0435\u0440\u043A\u0456\u043D\u0434\u0456\u043A\u0442\u0456\u04A3
        \u0448\u0435\u043A\u0442\u0435\u043B\u0443\u0456 \u043C\u0435\u043D \u04B1\u043B\u0442\u0442\u044B\u049B
        \u0431\u043E\u043B\u043C\u044B\u0441\u0442\u044B\u04A3  \u0442\u0440\u0430\u043D\u0441\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F\u043B\u0430\u043D\u0443\u044B
        \u0440\u0435\u0442\u0456\u043D\u0434\u0435 \xAB\u0417\u0430\u0440 \u0437\u0430\u043C\u0430\u043D\xBB
        \u0431\u043E\u043B\u044B\u043F \u049B\u0430\u043B\u0434\u044B"
      speakerName: 
      characterSprite: {fileID: 0}
      side: 0
