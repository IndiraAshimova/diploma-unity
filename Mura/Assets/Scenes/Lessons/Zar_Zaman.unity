--- !u!114 &1408758213
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1408758211}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 157a3517668cfd940b7f9d85d2eaae44, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    lines:
    - sentence: "1867-1868 \u0436\u044B\u043B\u0434\u0430\u0440\u0434\u0430\u0493\u044B
        \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u043B\u0430\u0440 \u043F\u0430\u0442\u0448\u0430\u043B\u044B\u049B
        \u0420\u0435\u0441\u0435\u0439\u0434\u0456\u04A3 \u049B\u0430\u0437\u0430\u049B
        \u0434\u0430\u043B\u0430\u0441\u044B\u043D \u0438\u043C\u043F\u0435\u0440\u0438\u044F\u043D\u044B\u04A3
        \u04E9\u0437\u0433\u0435  \u0431\u04E9\u043B\u0456\u043A\u0442\u0435\u0440\u0456\u043C\u0435\u043D
        \u0442\u043E\u043B\u044B\u049B \u049B\u043E\u0441\u044B\u043F \u0436\u0456\u0431\u0435\u0440\u0443\u0434\u0456
        \u043A\u04E9\u0437\u0434\u0435\u0433\u0435\u043D \u043E\u0442\u0430\u0440\u0448\u044B\u043B\u0434\u044B\u049B
        \u0441\u0430\u044F\u0441\u0430\u0442\u044B\u043D\u044B\u04A3 \u0448\u0435\u0448\u0443\u0448\u0456
        \u043A\u0435\u0437\u0435\u04A3\u0456  \u0431\u043E\u043B\u0434\u044B. \u0411\u04B1\u043B
        \u04E9\u0437\u0433\u0435\u0440\u0456\u0441\u0442\u0435\u0440 \u0434\u0259\u0441\u0442\u04AF\u0440\u043B\u0456
        \u0440\u0443\u043B\u044B\u049B \u0431\u0438\u043B\u0456\u043A\u0442\u0456
        \u0259\u043B\u0441\u0456\u0440\u0435\u0442\u0456\u043F, \u0436\u0435\u0440\u0433\u0456\u043B\u0456\u043A\u0442\u0456
        \u0431\u0430\u0439-\u043C\u0430\u043D\u0430\u043F\u0442\u0430\u0440\u0434\u044B
        \u0431\u0430\u0441\u049B\u0430\u0440\u0443  \u0436\u04AF\u0439\u0435\u0441\u0456\u043D\u0435\u043D
        \u044B\u0441\u044B\u0440\u044B\u043F, \u0430\u0439\u043C\u0430\u049B\u0442\u044B\u04A3
        \u0442\u0430\u0431\u0438\u0493\u0438 \u0431\u0430\u0439\u043B\u044B\u0493\u044B\u043D
        \u0435\u0440\u043A\u0456\u043D \u0438\u0435\u043C\u0434\u0435\u043D\u0443\u0433\u0435
        \u0436\u043E\u043B \u0430\u0448\u0442\u044B. \u041E\u0442\u0430\u0440\u043B\u0430\u0443 
        \u049B\u0430\u043C\u044B\u0442\u044B\u043D\u044B\u04A3 \u049B\u0430\u0442\u0442\u044B
        \u0431\u0430\u0442\u049B\u0430\u043D\u044B \u0441\u043E\u043D\u0448\u0430\u043B\u044B\u049B,
        \u0445\u0430\u043B\u044B\u049B\u0442\u044B\u04A3 \u0431\u0430\u0441\u044B\u043D\u0430
        \u0442\u04AF\u0441\u043A\u0435\u043D \u0431\u04B1\u043B \u0442\u0430\u0440\u0438\u0445\u0438
        \u049B\u0430\u0441\u0456\u0440\u0435\u0442 \u049B\u0430\u0437\u0430\u049B 
        \u0259\u0434\u0435\u0431\u0438\u0435\u0442\u0456\u043D\u0434\u0435 \xAB\u0417\u0430\u0440
        \u0437\u0430\u043C\u0430\u043D\xBB \u0430\u0493\u044B\u043C\u044B\u043D\u044B\u04A3
        \u0442\u0443\u0443\u044B\u043D\u0430 \u0441\u0435\u0431\u0435\u043F \u0431\u043E\u043B\u0434\u044B.
        \u041E\u0441\u044B \u043A\u0435\u0437\u0435\u04A3\u043D\u0456\u04A3 \u0448\u044B\u043D\u0430\u0439\u044B
        \u0431\u0435\u0439\u043D\u0435\u0441\u0456  \u043C\u0435\u043D \u043C\u04B1\u04A3-\u0437\u0430\u0440\u044B
        \u0428\u043E\u0440\u0442\u0430\u043D\u0431\u0430\u0439 \u049A\u0430\u043D\u0430\u0439\u04B1\u043B\u044B\u043D\u044B\u04A3
        \u0259\u0439\u0433\u0456\u043B\u0456 \xAB\u0417\u0430\u0440 \u0437\u0430\u043C\u0430\u043D\xBB
        \u0442\u043E\u043B\u0493\u0430\u0443\u044B\u043D\u0434\u0430 \u043A\u04E9\u0440\u043A\u0435\u043C 
        \u0441\u0438\u043F\u0430\u0442\u0442\u0430\u043B\u044B\u043F, \u0442\u04B1\u0442\u0430\u0441
        \u0434\u0259\u0443\u0456\u0440\u0434\u0456\u04A3 \u0441\u0438\u043C\u0432\u043E\u043B\u0434\u044B\u049B
        \u0430\u0442\u0430\u0443\u044B\u043D\u0430 \u0430\u0439\u043D\u0430\u043B\u0434\u044B.
        \u0410\u049B\u044B\u043D \u04E9\u0437 \u0436\u044B\u0440\u044B\u043D\u0434\u0430
        \u0436\u0435\u0440\u0434\u0456\u04A3  \u0442\u0430\u0440\u044B\u043B\u0443\u044B\u043D,
        \u0438\u043C\u0430\u043D\u043D\u044B\u04A3 \u049B\u0430\u0448\u0443\u044B\u043D
        \u0436\u0259\u043D\u0435 \u04B1\u043B\u0442\u0442\u044B\u049B \u0431\u043E\u043B\u043C\u044B\u0441\u0442\u044B\u04A3
        \u043A\u04AF\u0439\u0440\u0435\u0443\u0456\u043D \u0442\u0435\u0440\u0435\u04A3
        \u0442\u043E\u043B\u0493\u0430\u043D\u044B\u0441\u043F\u0435\u043D \u0436\u0435\u0442\u043A\u0456\u0437\u0435 
        \u0431\u0456\u043B\u0434\u0456. \u041E\u0441\u044B\u043B\u0430\u0439\u0448\u0430,
        \u043F\u0430\u0442\u0448\u0430\u043B\u044B\u049B \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u043B\u0430\u0440
        \u049B\u0430\u0437\u0430\u049B \u049B\u043E\u0493\u0430\u043C\u044B\u043D\u044B\u04A3
        \u0442\u04B1\u0440\u043C\u044B\u0441\u044B\u043D \u0493\u0430\u043D\u0430
        \u0435\u043C\u0435\u0441, \u043E\u043D\u044B\u04A3  \u0431\u04AF\u043A\u0456\u043B
        \u0440\u0443\u0445\u0430\u043D\u0438 \u0259\u043B\u0435\u043C\u0456\u043D
        \u04E9\u0437\u0433\u0435\u0440\u0442\u0456\u043F, \u0442\u0430\u0440\u0438\u0445\u0442\u0430
        \u04E9\u0448\u043F\u0435\u0441 \u043C\u04B1\u04A3\u0434\u044B \u0456\u0437
        \u049B\u0430\u043B\u0434\u044B\u0440\u0434\u044B."
      speakerName: 
      characterSprite: {fileID: 0}
      side: 0
  storyManager: {fileID: 535694282}
