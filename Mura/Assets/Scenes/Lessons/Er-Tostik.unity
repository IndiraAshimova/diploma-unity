--- !u!114 &867772278
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 867772276}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 157a3517668cfd940b7f9d85d2eaae44, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    sentences:
    - "\u0415\u0440\u0442\u0435, \u0435\u0440\u0442\u0435, \u0435\u0440\u0442\u0435\u0434\u0435,
      \u0435\u0448\u043A\u0456 \u0436\u04AF\u043D\u0456 \u0431\u04E9\u0440\u0442\u0435\u0434\u0435,
      \u0415\u0440 \u0422\u04E9\u0441\u0442\u0456\u043A \u0430\u0442\u0442\u044B
      \u0431\u0430\u0442\u044B\u0440 \u04E9\u043C\u0456\u0440 \u0441\u04AF\u0440\u0456\u043F\u0442\u0456.
      \u041E\u043B \u2014  \u0430\u0442\u0430-\u0430\u043D\u0430\u0441\u044B\u043D\u044B\u04A3
      \u04AF\u043C\u0456\u0442\u0456, \u0445\u0430\u043B\u049B\u044B\u043D\u044B\u04A3
      \u043C\u0430\u049B\u0442\u0430\u043D\u044B\u0448\u044B. \u0411\u0456\u0440
      \u043A\u04AF\u043D\u0456 \u043E\u043D\u044B\u04A3 \u0441\u0435\u0433\u0456\u0437
      \u0430\u0493\u0430\u0441\u044B \u0456\u0437-\u0442\u04AF\u0437\u0441\u0456\u0437
      \u0436\u043E\u0493\u0430\u043B\u044B\u043F  \u043A\u0435\u0442\u0435\u0434\u0456.
      \u0416\u0430\u0441 \u0422\u04E9\u0441\u0442\u0456\u043A \u049B\u043E\u043B\u044B\u043D\u0430
      \u049B\u0430\u0440\u0443 \u0430\u043B\u044B\u043F, \u0436\u04AF\u0440\u0435\u0433\u0456\u043D\u0435
      \u0441\u0435\u043D\u0456\u043C \u04B1\u044F\u043B\u0430\u0442\u044B\u043F,
      \u0442\u0443\u044B\u0441\u0442\u0430\u0440\u044B\u043D \u0456\u0437\u0434\u0435\u043F
      \u04B1\u0437\u0430\u049B \u0442\u0430  \u049B\u0430\u0443\u0456\u043F\u0442\u0456
      \u0441\u0430\u043F\u0430\u0440\u0493\u0430 \u0430\u0442\u0442\u0430\u043D\u0430\u0434\u044B."
    - 
    - "\u0415\u0440\u0442\u04E9\u0441\u0442\u0456\u043A \u0430\u0493\u0430\u043B\u0430\u0440\u044B\u043D
      \u0456\u0437\u0434\u0435\u043F, \u049B\u0430\u0440\u0430\u04A3\u0493\u044B
      \u0259\u0440\u0456 \u0436\u04B1\u043C\u0431\u0430\u049B \u0416\u0435\u0440
      \u0430\u0441\u0442\u044B \u0259\u043B\u0435\u043C\u0456\u043D\u0435 \u0441\u0430\u043F\u0430\u0440
      \u0448\u0435\u0433\u0435\u0434\u0456. \u0411\u04B1\u043B \u0434\u04AF\u043D\u0438\u0435\u0434\u0435 
      \u043A\u0435\u0437 \u043A\u0435\u043B\u0433\u0435\u043D \u0430\u0434\u0430\u043C\u043D\u044B\u04A3
      \u0436\u04AF\u0440\u0435\u0433\u0456 \u0434\u0430\u0443\u0430\u043B\u0430\u043C\u0430\u0439\u0442\u044B\u043D
      \u049B\u0430\u0443\u0456\u043F\u0442\u0435\u0440 \u043A\u04E9\u043F \u0435\u0434\u0456.
      \u0410\u043B\u0430\u0439\u0434\u0430 \u0422\u04E9\u0441\u0442\u0456\u043A\u0442\u0456\u04A3
      \u0431\u043E\u0439\u044B\u043D\u0434\u0430\u0493\u044B  \u0431\u0430\u0442\u044B\u043B\u0434\u044B\u049B
      \u043E\u043D\u044B \u0430\u043B\u0493\u0430 \u0436\u0435\u0442\u0435\u043B\u0435\u0434\u0456. "
    - "\u0411\u0456\u0440\u0434\u0435 \u043E\u043B \u0431\u0438\u0456\u043A\u0442\u0456\u0433\u0456
      \u043A\u04E9\u043A \u0442\u0456\u0440\u0435\u0433\u0435\u043D, \u0431\u04B1\u0442\u0430\u0493\u044B
      \u0436\u0435\u0440 \u0442\u0456\u0440\u0435\u0433\u0435\u043D \u0430\u043B\u044B\u043F
      \u0411\u0259\u0439\u0442\u0435\u0440\u0435\u043A\u0442\u0456\u04A3 \u0442\u04AF\u0431\u0456\u043D\u0435
      \u043A\u0435\u043B\u0435\u0434\u0456. \u0410\u0493\u0430\u0448\u0442\u044B\u04A3 
      \u0431\u0430\u0441\u044B\u043D\u0434\u0430 \u043A\u0438\u0435\u043B\u0456 \u0421\u0430\u043C\u04B1\u0440\u044B\u049B
      \u049B\u04B1\u0441\u0442\u044B\u04A3 \u0431\u0430\u043B\u0430\u043F\u0430\u043D\u0434\u0430\u0440\u044B
      \u0448\u044B\u0440\u044B\u043B\u0434\u0430\u043F, \u043A\u04E9\u043C\u0435\u043A
      \u0441\u04B1\u0440\u0430\u043F \u0436\u0430\u0442\u044B\u0440 \u0435\u043A\u0435\u043D.
      \u0421\u0435\u0431\u0435\u0431\u0456,  \u0436\u044B\u043B \u0441\u0430\u0439\u044B\u043D
      \u0411\u0259\u0439\u0442\u0435\u0440\u0435\u043A\u0442\u0456\u04A3 \u0442\u0430\u043C\u044B\u0440\u044B\u043D\u0430\u043D
      \u04E9\u0440\u043C\u0435\u043B\u0435\u043F \u0448\u044B\u0493\u0430\u0442\u044B\u043D
      \u0410\u0439\u0434\u0430\u04BB\u0430\u0440 \u0431\u0430\u043B\u0430\u043F\u0430\u043D\u0434\u0430\u0440\u0434\u044B
      \u0436\u0435\u043F \u049B\u043E\u044F\u0434\u044B  \u0435\u043A\u0435\u043D. "
    - "\u0415\u0440\u0442\u04E9\u0441\u0442\u0456\u043A \u043E\u0439\u043B\u0430\u043D\u0431\u0430\u0441\u0442\u0430\u043D
      \u0410\u0439\u0434\u0430\u04BB\u0430\u0440\u043C\u0435\u043D \u0430\u0439\u049B\u0430\u0441\u049B\u0430
      \u0442\u04AF\u0441\u0435\u0434\u0456. \u0411\u04B1\u043B \u0442\u0435\u043A
      \u043A\u04AF\u0448\u0442\u0456\u04A3 \u0435\u043C\u0435\u0441, \u0440\u0443\u0445\u0442\u044B\u04A3
      \u0441\u044B\u043D\u0430\u0493\u044B  \u0435\u0434\u0456. \u041E\u043B \u04E9\u0437\u0456\u043D\u0456\u04A3
      \u04E9\u0442\u043A\u0456\u0440 \u049B\u044B\u043B\u044B\u0448\u044B\u043C\u0435\u043D
      \u0437\u04B1\u043B\u044B\u043C\u0434\u044B\u049B\u0442\u044B \u0436\u0435\u04A3\u0456\u043F,
      \u0431\u0430\u043B\u0430\u043F\u0430\u043D\u0434\u0430\u0440\u0434\u044B \u0430\u0436\u0430\u043B\u0434\u0430\u043D
      \u0430\u043C\u0430\u043D \u0430\u043B\u044B\u043F  \u049B\u0430\u043B\u0430\u0434\u044B. "
    - "\u0411\u0456\u0440\u0430\u049B \u0441\u044B\u043D\u0430\u049B \u043C\u04B1\u043D\u044B\u043C\u0435\u043D
      \u0431\u0456\u0442\u043A\u0435\u043D \u0436\u043E\u049B. \u0416\u0435\u0440
      \u0430\u0441\u0442\u044B\u043D\u044B\u04A3 \u0431\u0438\u043B\u0435\u0443\u0448\u0456\u0441\u0456
      \u043E\u043D\u044B\u04A3 \u0442\u0430\u043F\u049B\u044B\u0440\u043B\u044B\u0493\u044B\u043D
      \u0442\u0435\u043A\u0441\u0435\u0440\u0433\u0456\u0441\u0456  \u043A\u0435\u043B\u0435\u0434\u0456.
      \u041E\u0493\u0430\u043D \u0434\u04AF\u043D\u0438\u0435\u043D\u0456\u04A3 \u049B\u04B1\u043F\u0438\u044F\u0441\u044B
      \u0442\u0443\u0440\u0430\u043B\u044B \u0436\u04B1\u043C\u0431\u0430\u049B \u0441\u04B1\u0440\u0430\u049B\u0442\u0430\u0440
      \u049B\u043E\u0439\u044B\u043B\u0430\u0434\u044B. \u0415\u0440\u0442\u04E9\u0441\u0442\u0456\u043A
      \u0431\u04B1\u043B \u0436\u0435\u0440\u0434\u0435 \u0434\u0435  \u043C\u04AF\u0434\u0456\u0440\u043C\u0435\u0439,
      \"\u04B0\u0439\u049B\u044B - \u0442\u0259\u0442\u0442\u0456, \u0410\u043D\u0430\u043D\u044B\u04A3
      \u049B\u043E\u043B\u044B - \u0436\u04B1\u043C\u0441\u0430\u049B, \u0416\u0435\u0440
      - \u049B\u0430\u0442\u0442\u044B\" \u0434\u0435\u043F \u0436\u0430\u0443\u0430\u043F
      \u0431\u0435\u0440\u0435\u0434\u0456. "
    - "\u041E\u0441\u044B\u043B\u0430\u0439\u0448\u0430, \u0415\u0440\u0442\u04E9\u0441\u0442\u0456\u043A
      \u0442\u0435\u043A \u0431\u0456\u043B\u0435\u043A \u043A\u04AF\u0448\u0456\u043C\u0435\u043D
      \u0435\u043C\u0435\u0441, \u0430\u049B\u044B\u043B-\u043F\u0430\u0440\u0430\u0441\u0430\u0442\u044B\u043C\u0435\u043D
      \u0434\u0435 \u043D\u0430\u0493\u044B\u0437 \u0431\u0430\u0442\u044B\u0440
      \u0435\u043A\u0435\u043D\u0456\u043D  \u0434\u0259\u043B\u0435\u043B\u0434\u0435\u0439\u0434\u0456.
      \u0420\u0438\u0437\u0430 \u0431\u043E\u043B\u0493\u0430\u043D \u0421\u0430\u043C\u04B1\u0440\u044B\u049B
      \u049B\u04B1\u0441 \u0431\u0430\u0442\u044B\u0440\u0434\u044B \u049B\u0430\u043D\u0430\u0442\u044B\u043D\u0430
      \u049B\u043E\u043D\u0434\u044B\u0440\u044B\u043F, \u0436\u0430\u0440\u044B\u049B
      \u0434\u04AF\u043D\u0438\u0435\u0433\u0435 \u0430\u043B\u044B\u043F  \u0448\u044B\u0493\u0430\u0434\u044B. "
    names: ---
