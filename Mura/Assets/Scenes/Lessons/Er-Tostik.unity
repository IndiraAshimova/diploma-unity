--- !u!114 &97431238
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 97431236}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: dc984ce53dbd2e04d9f5d15d34cae4c2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    lines:
    - sentence: "\u0422\u043E\u049B\u0442\u0430, \u0431\u0430\u0442\u044B\u0440!
        \u0421\u0435\u043D\u0456\u04A3 \u0431\u0456\u043B\u0435\u0433\u0456\u04A3
        \u0436\u0443\u0430\u043D, \u0436\u04AF\u0440\u0435\u0433\u0456\u04A3 \u0442\u04AF\u043A\u0442\u0456
        \u0435\u043A\u0435\u043D\u0456\u043D \u043A\u04E9\u0440\u0434\u0456\u043C.
        \u0411\u0456\u0440\u0430\u049B \u0416\u0435\u0440 \u0430\u0441\u0442\u044B 
        \u0259\u043B\u0435\u043C\u0456\u043D\u0434\u0435 \u0442\u0435\u043A \u043A\u04AF\u0448\u043F\u0435\u043D
        \u0436\u0435\u04A3\u0456\u0441\u043A\u0435 \u0436\u0435\u0442\u0435 \u0430\u043B\u043C\u0430\u0439\u0441\u044B\u04A3.
        \u0415\u0433\u0435\u0440 \u043C\u044B\u043D\u0430 \u0431\u0430\u043B\u0430\u043F\u0430\u043D\u0434\u0430\u0440\u0434\u044B
        \u0430\u043C\u0430\u043D \u0430\u043B\u044B\u043F \u049B\u0430\u043B\u0493\u044B\u04A3 
        \u043A\u0435\u043B\u0441\u0435, \u043C\u0435\u043D\u0456\u04A3 \u04AF\u0448
        \u0441\u04B1\u0440\u0430\u0493\u044B\u043C\u0430 \u0436\u0430\u0443\u0430\u043F
        \u0431\u0435\u0440. \u0422\u0430\u043F\u0441\u0430\u04A3 - \u0436\u043E\u043B\u044B\u04A3
        \u0430\u0448\u044B\u049B, \u0442\u0430\u043F\u043F\u0430\u0441\u0430\u04A3
        - \u0431\u0430\u0441\u044B\u04A3 \u043E\u0441\u044B  \u0411\u0259\u0439\u0442\u0435\u0440\u0435\u043A\u0442\u0456\u04A3
        \u0442\u04AF\u0431\u0456\u043D\u0434\u0435 \u049B\u0430\u043B\u0430\u0434\u044B! "
      speakerName: "\u0410\u0439\u0434\u0430\u04BB\u0430\u0440"
      characterSprite: {fileID: 21300000, guid: b6d6ec0eaabe02f4c8e0848ffd5a20af, type: 3}
      side: 1
    - sentence: "\u0421\u04E9\u0439\u043B\u0435, \u0410\u0439\u0434\u0430\u04BB\u0430\u0440!
        \u049A\u0430\u0437\u0430\u049B \u0431\u0430\u0442\u044B\u0440\u044B \u0430\u0436\u0430\u043B\u0434\u0430\u043D
        \u049B\u043E\u0440\u044B\u049B\u043F\u0430\u0439\u0434\u044B, \u0431\u0456\u0440\u0430\u049B
        \u0441\u04E9\u0437\u0434\u0435\u043D \u0434\u0435  \u043C\u04AF\u0434\u0456\u0440\u043C\u0435\u0439\u0434\u0456.
        \u0422\u0435\u043A \u0431\u0456\u043B\u0435\u043A\u043A\u0435 \u0435\u043C\u0435\u0441,
        \u0430\u049B\u044B\u043B\u0493\u0430 \u0434\u0430 \u0441\u0435\u043D\u0433\u0435\u043D
        \u0435\u0440\u043C\u0456\u0437. \u049A\u043E\u044F\u0442\u044B\u043D \u0436\u04B1\u043C\u0431\u0430\u0493\u044B\u04A3\u0434\u044B
        \u0430\u0439\u0442! "
      speakerName: "\u0415\u0440 \u0422\u04E9\u0441\u0442\u0456\u043A"
      characterSprite: {fileID: 21300000, guid: c3a7b852de7075f4d8ee8740ce5b9729, type: 3}
      side: 0
    - sentence: "\u0416\u0430\u049B\u0441\u044B... \u041E\u043D\u0434\u0430 \u0430\u0439\u0442\u0448\u044B
        \u043C\u0430\u0493\u0430\u043D: \u0414\u04AF\u043D\u0438\u0435\u0434\u0435
        \u043D\u0435 \u0442\u0259\u0442\u0442\u0456?"
      speakerName: "\u0410\u0439\u0434\u0430\u04BB\u0430\u0440"
      characterSprite: {fileID: 21300000, guid: b6d6ec0eaabe02f4c8e0848ffd5a20af, type: 3}
      side: 1
    - sentence: "\u0414\u04AF\u043D\u0438\u0435\u0434\u0435\u0433\u0456 \u0435\u04A3
        \u0442\u0259\u0442\u0442\u0456 \u043D\u0259\u0440\u0441\u0435 - \u0431\u0430\u043B
        \u0434\u0430 \u0435\u043C\u0435\u0441, \u049B\u0430\u043D\u0442 \u0442\u0430
        \u0435\u043C\u0435\u0441. \u0410\u0434\u0430\u043C \u0431\u0430\u043B\u0430\u0441\u044B
        \u04AF\u0448\u0456\u043D \u0435\u04A3  \u0442\u0259\u0442\u0442\u0456 \u043D\u0259\u0440\u0441\u0435
        - \u04B1\u0439\u049B\u044B. \u04E8\u0439\u0442\u043A\u0435\u043D\u0456 \u04B1\u0439\u049B\u044B
        - \u0436\u0430\u043D\u043D\u044B\u04A3 \u0442\u044B\u043D\u044B\u0448\u0442\u044B\u0493\u044B,
        \u0442\u0259\u043D\u0456\u043D\u0456\u04A3 \u0434\u0435\u043C\u0430\u043B\u044B\u0441\u044B. "
      speakerName: "\u0415\u0440 \u0422\u04E9\u0441\u0442\u0456\u043A"
      characterSprite: {fileID: 21300000, guid: c3a7b852de7075f4d8ee8740ce5b9729, type: 3}
      side: 0
    - sentence: "\u0414\u04B1\u0440\u044B\u0441 \u0442\u0430\u043F\u0442\u044B\u04A3,
        \u0431\u0430\u0442\u044B\u0440... \u0415\u043A\u0456\u043D\u0448\u0456 \u0441\u04B1\u0440\u0430\u0493\u044B\u043C:
        \u0414\u04AF\u043D\u0438\u0435\u0434\u0435 \u043D\u0435 \u0436\u04B1\u043C\u0441\u0430\u049B?"
      speakerName: "\u0410\u0439\u0434\u0430\u04BB\u0430\u0440"
      characterSprite: {fileID: 21300000, guid: b6d6ec0eaabe02f4c8e0848ffd5a20af, type: 3}
      side: 1
    - sentence: "\u0414\u04AF\u043D\u0438\u0435\u0434\u0435\u0433\u0456 \u0435\u04A3
        \u0436\u04B1\u043C\u0441\u0430\u049B \u043D\u0259\u0440\u0441\u0435 - \u043C\u0430\u043C\u044B\u049B
        \u0442\u0430 \u0435\u043C\u0435\u0441, \u0436\u0456\u0431\u0435\u043A \u0442\u0435
        \u0435\u043C\u0435\u0441. \u041E\u043B - \u0410\u043D\u0430\u043D\u044B\u04A3 
        \u049B\u043E\u043B\u044B. \u0411\u0430\u043B\u0430 \u04AF\u0448\u0456\u043D
        \u0430\u043D\u0430\u043D\u044B\u04A3 \u0430\u044F\u043B\u044B \u0430\u043B\u0430\u049B\u0430\u043D\u044B\u043D\u0430\u043D
        \u0430\u0440\u0442\u044B\u049B \u0436\u04B1\u043C\u0441\u0430\u049B\u0442\u044B\u049B
        \u0436\u043E\u049B. "
      speakerName: "\u0415\u0440 \u0422\u04E9\u0441\u0442\u0456\u043A"
      characterSprite: {fileID: 21300000, guid: c3a7b852de7075f4d8ee8740ce5b9729, type: 3}
      side: 0
    - sentence: "\u041C\u04B1\u043D\u044B \u0434\u0430 \u0431\u0456\u043B\u0434\u0456\u04A3!
        \u0421\u043E\u04A3\u0493\u044B \u0441\u04B1\u0440\u0430\u0493\u044B\u043C\u0434\u044B
        \u0442\u044B\u04A3\u0434\u0430: \u0414\u04AF\u043D\u0438\u0435\u0434\u0435
        \u043D\u0435 \u049B\u0430\u0442\u0442\u044B? "
      speakerName: "\u0410\u0439\u0434\u0430\u04BB\u0430\u0440"
      characterSprite: {fileID: 21300000, guid: b6d6ec0eaabe02f4c8e0848ffd5a20af, type: 3}
      side: 1
    - sentence: "\u0414\u04AF\u043D\u0438\u0435\u0434\u0435\u0433\u0456 \u0435\u04A3
        \u049B\u0430\u0442\u0442\u044B \u043D\u0259\u0440\u0441\u0435 - \u0442\u0430\u0441
        \u0442\u0430 \u0435\u043C\u0435\u0441, \u0442\u0435\u043C\u0456\u0440 \u0434\u0435
        \u0435\u043C\u0435\u0441. \u041E\u043B - \u049B\u0430\u0440\u0430 \u0436\u0435\u0440.
        \u0411\u0259\u0440\u0456\u043C\u0456\u0437\u0434\u0456  \u043A\u04E9\u0442\u0435\u0440\u0456\u043F
        \u0442\u04B1\u0440\u0493\u0430\u043D \u0434\u0430 \u0436\u0435\u0440, \u0430\u049B\u044B\u0440\u044B\u043D\u0434\u0430
        \u049B\u043E\u0439\u043D\u0430\u0443\u044B\u043D\u0430 \u0430\u043B\u0430\u0442\u044B\u043D
        \u0434\u0430 \u0436\u0435\u0440. \u0416\u0435\u0440\u0434\u0435\u043D \u049B\u0430\u0442\u0442\u044B,
        \u0436\u0435\u0440\u0434\u0435\u043D \u049B\u0443\u0430\u0442\u0442\u044B 
        \u0435\u0448\u0442\u0435\u04A3\u0435 \u0436\u043E\u049B! "
      speakerName: "\u0415\u0440 \u0422\u04E9\u0441\u0442\u0456\u043A"
      characterSprite: {fileID: 21300000, guid: c3a7b852de7075f4d8ee8740ce5b9729, type: 3}
      side: 0
    - sentence: "\u049A\u0430\u043F! \u0421\u0435\u043D\u0456\u04A3 \u0431\u0456\u043B\u0435\u0433\u0456\u04A3\u043D\u0435\u043D
        \u0431\u04B1\u0440\u044B\u043D, \u0431\u0456\u043B\u0456\u043C\u0456\u04A3
        \u04E9\u0442\u043A\u0456\u0440 \u0435\u043A\u0435\u043D. \u0410\u049B\u044B\u043B\u044B
        \u0430\u0441\u049B\u0430\u043D \u0430\u0434\u0430\u043C\u0434\u044B \u0436\u04B1\u0442\u0443
        -  \u043C\u0430\u0493\u0430\u043D \u0430\u0440\u0430\u043C. \u0416\u043E\u043B
        \u0441\u0435\u043D\u0456\u043A\u0456, \u0415\u0440 \u0422\u04E9\u0441\u0442\u0456\u043A!
        \u04E8\u0442! "
      speakerName: "\u0410\u0439\u0434\u0430\u04BB\u0430\u0440"
      characterSprite: {fileID: 21300000, guid: b6d6ec0eaabe02f4c8e0848ffd5a20af, type: 3}
      side: 1
--- !u!1001 &194008043
PrefabInstance:
  m_ObjectHideFlags: 0
