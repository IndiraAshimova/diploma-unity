--- !u!114 &642728263
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 642728262}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 157a3517668cfd940b7f9d85d2eaae44, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    lines:
    - sentence: "\u049A\u0430\u0437\u0430\u049B \u0436\u0435\u0440\u0456\u043D\u0434\u0435,
        \u0416\u0430\u0493\u0430\u043B\u0431\u0430\u0439\u043B\u044B \u0435\u043B\u0456\u043D\u0434\u0435
        \u0431\u0430\u0439\u043B\u044B\u0493\u044B \u0430\u0441\u049B\u0430\u043D
        \u0411\u0430\u0437\u0430\u0440\u0431\u0430\u0439 \u0430\u0442\u0442\u044B
        \u049B\u0430\u0434\u0456\u0440\u043B\u0456 \u043A\u0456\u0441\u0456 \u0431\u043E\u043B\u0493\u0430\u043D
        \u0435\u043A\u0435\u043D. \u0411\u0430\u0437\u0430\u0440\u0431\u0430\u0439\u0434\u044B\u04A3
        \u0435\u043A\u0456 \u04B1\u043B\u044B \u0431\u043E\u043B\u0430\u0434\u044B:
        \u04AF\u043B\u043A\u0435\u043D\u0456 \u2013 \u0422\u04E9\u043B\u0435\u0433\u0435\u043D,
        \u043A\u0456\u0448\u0456\u0441\u0456 \u2013 \u0421\u0430\u043D\u0441\u044B\u0437\u0431\u0430\u0439.
        \u0415\u043A\u0435\u0443\u0456 \u0434\u0435 \u0435\u0440\u0436\u04AF\u0440\u0435\u043A
        \u0431\u0430\u0442\u044B\u0440 \u0431\u043E\u043B\u044B\u043F \u04E9\u0441\u0435\u0434\u0456.
        \u0422\u04E9\u043B\u0435\u0433\u0435\u043D \u043E\u043D \u0441\u0435\u0433\u0456\u0437
        \u0436\u0430\u0441\u049B\u0430 \u0442\u043E\u043B\u0493\u0430\u043D\u0434\u0430,
        \u0259\u043A\u0435\u0441\u0456 \u043E\u0493\u0430\u043D \u043B\u0430\u0439\u044B\u049B\u0442\u044B
        \u0436\u0430\u0440 \u0442\u0430\u043F\u043F\u0430\u049B \u0431\u043E\u043B\u044B\u043F
        \u0442\u0430\u043B\u0430\u0439 \u049B\u044B\u0437\u0434\u044B \u043A\u04E9\u0440\u0441\u0435\u0442\u0435\u0434\u0456,
        \u0431\u0456\u0440\u0430\u049B \u0422\u04E9\u043B\u0435\u0433\u0435\u043D\u043D\u0456\u04A3
        \u043A\u04E9\u04A3\u0456\u043B\u0456 \u0435\u0448\u043A\u0456\u043C\u0433\u0435
        \u0442\u043E\u043B\u043C\u0430\u0439\u0434\u044B. \u0411\u0430\u0437\u0430\u0440\u0431\u0430\u0439
        \u04B1\u043B\u044B\u043D\u0430 \u049B\u0430\u043F\u0430 \u0431\u043E\u043B\u044B\u043F:
        \xAB\u04E8\u0437\u0456 \u0436\u0430\u049B\u0442\u044B\u0440\u0493\u0430\u043D\u044B\u043D
        \u0430\u043B\u0441\u044B\u043D\xBB, \u2013 \u0434\u0435\u043F \u0442\u043E\u049B\u0442\u0430\u0439\u0434\u044B. "
      speakerName: "\u0410\u0432\u0442\u043E\u0440"
      characterSprite: {fileID: 21300000, guid: 0aaffdb02bd1d614db0f4e8c8c9183a2, type: 3}
      side: 1
    - sentence: "\u041A\u04AF\u043D\u0434\u0435\u0440\u0434\u0456\u04A3 \u0431\u0456\u0440\u0456\u043D\u0434\u0435
        \u0411\u0430\u0437\u0430\u0440\u0431\u0430\u0439\u0434\u044B\u04A3 \u04AF\u0439\u0456\u043D\u0435
        \u041D\u0430\u0443\u0440\u044B\u0437\u0431\u0430\u0439 \u0435\u0441\u0456\u043C\u0434\u0456
        \u049B\u0430\u0440\u0442 \u0441\u0430\u0443\u0434\u0430\u0433\u0435\u0440
        \u049B\u043E\u043D\u0430\u0434\u044B. \u041D\u0430\u0443\u0440\u044B\u0437\u0431\u0430\u0439 
        \u0422\u04E9\u043B\u0435\u0433\u0435\u043D\u043D\u0456\u04A3 \u0441\u044B\u043D\u044B\u043D\u0430
        \u0440\u0438\u0437\u0430 \u0431\u043E\u043B\u044B\u043F, \u043E\u043D\u044B
        \u04E9\u0437 \u0435\u043B\u0456\u043D\u0434\u0435\u0433\u0456 \u0441\u04B1\u043B\u0443
        \u049B\u044B\u0437\u0434\u0430\u0440\u0434\u044B \u043A\u04E9\u0440\u0443\u0433\u0435
        \u0448\u0430\u049B\u044B\u0440\u0430\u0434\u044B.  \u0411\u0430\u0437\u0430\u0440\u0431\u0430\u0439
        \u04B1\u043B\u044B\u043D\u0430 \u0431\u0430\u0442\u0430\u0441\u044B\u043D
        \u0431\u0435\u0440\u0456\u043F, \u041D\u0430\u0443\u0440\u044B\u0437\u0431\u0430\u0439\u043C\u0435\u043D
        \u0431\u0456\u0440\u0433\u0435 \u0410\u049B \u0416\u0430\u0439\u044B\u049B
        \u0430\u0443\u044B\u043B\u044B\u043D\u0430 \u0430\u0442\u0442\u0430\u043D\u0434\u044B\u0440\u0430\u0434\u044B."
      speakerName: "\u0410\u0432\u0442\u043E\u0440"
      characterSprite: {fileID: 0}
      side: 0
    - sentence: "\u0410\u049B \u0416\u0430\u0439\u044B\u049B\u049B\u0430 \u043A\u0435\u043B\u0433\u0435\u043D
        \u0441\u043E\u04A3, \u0422\u04E9\u043B\u0435\u0433\u0435\u043D \u0435\u043B
        \u0456\u0448\u0456\u043D\u0435 \u0436\u0430\u0440 \u0441\u0430\u043B\u0430\u0434\u044B.
        \xAB\u049A\u044B\u0437\u044B \u0436\u0430\u049B\u0441\u0430 \u0434\u0430,
        \u0436\u0430\u049B\u043F\u0430\u0441\u0430 \u0434\u0430, \u0431\u0456\u0440
        \u0436\u043E\u0440\u0493\u0430 \u0431\u0435\u0440\u0435\u043C\u0456\u043D\xBB
        \u0434\u0435\u043F \u0436\u043E\u043C\u0430\u0440\u0442\u0442\u044B\u049B
        \u0442\u0430\u043D\u044B\u0442\u0430\u0434\u044B. \u0421\u043E\u043B \u0435\u043B\u0434\u0456\u04A3
        \u0421\u044B\u0440\u043B\u044B\u0431\u0430\u0439 \u0430\u0442\u0442\u044B
        \u0442\u04E9\u0440\u0435\u0441\u0456\u043D\u0456\u04A3 \u049A\u0430\u0440\u0448\u044B\u0493\u0430
        \u0435\u0441\u0456\u043C\u0434\u0456 \u0448\u0435\u0448\u0435\u043D \u0443\u0259\u0437\u0456\u0440\u0456
        \u0422\u04E9\u043B\u0435\u0433\u0435\u043D\u043D\u0456\u04A3 \u0434\u0430\u04A3\u049B\u044B\u043D
        \u0435\u0441\u0442\u0456\u043F, \u043E\u043D\u044B\u043C\u0435\u043D \u0436\u04AF\u0437\u0434\u0435\u0441\u0443\u0433\u0435
        \u043A\u0435\u043B\u0435\u0434\u0456. \u0422\u04E9\u043B\u0435\u0433\u0435\u043D
        \u043C\u0435\u043D \u049A\u0430\u0440\u0448\u044B\u0493\u0430 \u043E\u04A3\u0430\u0448\u0430
        \u0441\u04E9\u0439\u043B\u0435\u0441\u0456\u043F, \u0442\u0456\u043B \u0442\u0430\u0431\u044B\u0441\u0430\u0434\u044B.
        \u049A\u0430\u0440\u0448\u044B\u0493\u0430 \u0421\u044B\u0440\u043B\u044B\u0431\u0430\u0439\u0434\u044B\u04A3
        \u0430\u0439\u0434\u0430\u0439 \u0441\u04B1\u043B\u0443 \u049B\u044B\u0437\u044B
        \u0416\u0456\u0431\u0435\u043A \u0442\u0443\u0440\u0430\u043B\u044B \u0430\u0439\u0442\u044B\u043F,
        \u0422\u04E9\u043B\u0435\u0433\u0435\u043D\u0433\u0435 \u043E\u043D\u044B
        \u043A\u04E9\u0440\u0441\u0435\u0442\u0443\u0433\u0435 \u0443\u0259\u0434\u0435
        \u0431\u0435\u0440\u0435\u0434\u0456. \u0422\u04E9\u043B\u0435\u0433\u0435\u043D
        \u049A\u0430\u0440\u0448\u044B\u0493\u0430\u0493\u0430 \u0440\u0438\u0437\u0430
        \u0431\u043E\u043B\u044B\u043F, \u0435\u043A\u0456 \u0436\u043E\u0440\u0493\u0430
        \u0441\u044B\u0439\u043B\u0430\u0439\u0434\u044B. "
      speakerName: "\u0410\u0432\u0442\u043E\u0440"
      characterSprite: {fileID: 21300000, guid: 3dd3a115e26660344a751b75c5a1506e, type: 3}
      side: 0
    - sentence: "\u0415\u043B \u0436\u0430\u0439\u043B\u0430\u0443\u0493\u0430 \u043A\u04E9\u0448\u0456\u043F
        \u0431\u0430\u0440\u0430 \u0436\u0430\u0442\u049B\u0430\u043D\u0434\u0430,
        \u049A\u0430\u0440\u0448\u044B\u0493\u0430 \u0422\u04E9\u043B\u0435\u0433\u0435\u043D\u0433\u0435
        \u0416\u0456\u0431\u0435\u043A\u0442\u0456 \u043A\u04E9\u0448 \u04AF\u0441\u0442\u0456\u043D\u0435\u043D
        \u043A\u04E9\u0440\u0441\u0435\u0442\u043F\u0435\u043A \u0431\u043E\u043B\u0430\u0434\u044B.
        \u0422\u04E9\u043B\u0435\u0433\u0435\u043D\u043D\u0456\u04A3 \u0430\u043B\u0434\u044B\u043D\u0430\u043D
        \u043E\u043D \u0431\u0456\u0440 \u0441\u0430\u043B\u0442\u0430\u043D\u0430\u0442\u0442\u044B
        \u043A\u04E9\u0448 \u04E9\u0442\u0435\u0434\u0456. \u018F\u0440 \u043A\u04E9\u0448\u0442\u0456\u04A3
        \u0430\u043B\u0434\u044B\u043D\u0434\u0430\u0493\u044B \u0441\u04B1\u043B\u0443
        \u049B\u044B\u0437\u0434\u0430\u0440\u0434\u044B \u043A\u04E9\u0440\u0433\u0435\u043D
        \u0441\u0430\u0439\u044B\u043D \u0422\u04E9\u043B\u0435\u0433\u0435\u043D:
        \xAB\u041E\u0441\u044B \u043C\u0430?\xBB \u2013 \u0434\u0435\u043F \u04AF\u043C\u0456\u0442\u0442\u0435\u043D\u0435\u0434\u0456,
        \u0431\u0456\u0440\u0430\u049B \u049A\u0430\u0440\u0448\u044B\u0493\u0430:
        \xAB\u0411\u04B1\u043B \u0416\u0456\u0431\u0435\u043A  \u0435\u043C\u0435\u0441\xBB,
        \u2013 \u0434\u0435\u043F \u0436\u0430\u0443\u0430\u043F \u0431\u0435\u0440\u0435\u0434\u0456.
        \u0415\u04A3 \u0441\u043E\u04A3\u044B\u043D\u0434\u0430 \u0416\u0456\u0431\u0435\u043A\u0442\u0456\u04A3
        \u0430\u043D\u0430\u0441\u044B\u043D\u044B\u04A3 \u043A\u04E9\u0448\u0456\u043D\u0435
        \u0436\u0435\u0442\u0435\u0434\u0456. \u0410\u043D\u0430\u0441\u044B \u0416\u0456\u0431\u0435\u043A\u0442\u0456\u04A3
        \u043A\u04AF\u043D \u0442\u0438\u043C\u0435\u0441\u0456\u043D \u0434\u0435\u043F,
        \u0435\u0440\u0442\u0435\u043C\u0435\u043D \u043A\u04E9\u043A \u043A\u04AF\u0439\u043C\u0435\u0433\u0435
        \u043C\u0456\u043D\u0456\u043F \u0456\u043B\u0433\u0435\u0440\u0456 \u043A\u0435\u0442\u043A\u0435\u043D\u0456\u043D
        \u0430\u0439\u0442\u0430\u0434\u044B. "
      speakerName: "\u0410\u0432\u0442\u043E\u0440"
      characterSprite: {fileID: 21300000, guid: 0aaffdb02bd1d614db0f4e8c8c9183a2, type: 3}
      side: 1
    - sentence: "\u0422\u04E9\u043B\u0435\u0433\u0435\u043D \u043A\u04AF\u0439\u043C\u0435\u0433\u0435
        \u0436\u0435\u0442\u0456\u043F, \u04AF\u0448 \u0440\u0435\u0442 \u0434\u0430\u0443\u044B\u0441\u0442\u0430\u0441\u0430
        \u0434\u0430, \u0416\u0456\u0431\u0435\u043A \u0436\u0430\u0443\u0430\u043F
        \u0431\u0435\u0440\u043C\u0435\u0439\u0434\u0456. \u0422\u04E9\u043B\u0435\u0433\u0435\u043D
        \u049B\u0430\u0434\u0456\u0440\u0456\u043C \u043A\u0435\u0442\u0442\u0456
        \u043C\u0435 \u0434\u0435\u043F \u04E9\u043A\u0456\u043D\u0456\u043F, \u043A\u0435\u0440\u0456
        \u049B\u0430\u0439\u0442\u043F\u0430\u049B \u0431\u043E\u043B\u0493\u0430\u043D\u0434\u0430,
        \u049A\u0430\u0440\u0448\u044B\u0493\u0430 \u049B\u0443\u044B\u043F \u0436\u0435\u0442\u0456\u043F,
        \u0416\u0456\u0431\u0435\u043A\u0442\u0456\u04A3 \u043A\u04AF\u0439\u043C\u0435\u0441\u0456\u043D\u0435 
        \u0436\u0430\u049B\u044B\u043D\u0434\u0430\u0439\u0434\u044B. \u049A\u0430\u0440\u0448\u044B\u0493\u0430
        \u0416\u0456\u0431\u0435\u043A\u043A\u0435 \u0430\u049B\u044B\u043B \u0430\u0439\u0442\u044B\u043F,
        \u0422\u04E9\u043B\u0435\u0433\u0435\u043D\u043D\u0456\u04A3 \u0442\u0435\u043A\u0442\u0456\u043B\u0456\u0433\u0456
        \u043C\u0435\u043D \u0431\u0430\u0442\u044B\u0440\u043B\u044B\u0493\u044B\u043D
        \u0436\u0435\u0442\u043A\u0456\u0437\u0435\u0434\u0456. \u0416\u0456\u0431\u0435\u043A
        \u0430\u043B\u0493\u0430\u0448\u044B\u043D\u0434\u0430 \u0430\u0448\u0443\u043B\u0430\u043D\u044B\u043F,
        \u049A\u0430\u0440\u0448\u044B\u0493\u0430\u043D\u044B \xAB\u043C\u0435\u043D\u0456
        \u0435\u043A\u0456 \u0442\u0430\u0439\u0493\u0430 \u0441\u0430\u0442\u044B\u043F
        \u0436\u0456\u0431\u0435\u0440\u0434\u0456\u04A3 \u0431\u0435?\xBB \u0434\u0435\u043F
        \u0430\u0439\u044B\u043F\u0442\u0430\u0493\u0430\u043D\u044B\u043C\u0435\u043D,
        \u043A\u0435\u0439\u0456\u043D \u049A\u0430\u0440\u0448\u044B\u0493\u0430\u043D\u044B\u04A3
        \u0430\u0434\u0430\u043B \u043D\u0438\u0435\u0442\u0456\u043D \u0442\u04AF\u0441\u0456\u043D\u0456\u043F,
        \u043A\u04AF\u0439\u043C\u0435\u043D\u0456\u04A3 \u0435\u0441\u0456\u0433\u0456\u043D
        \u0430\u0448\u044B\u043F, \u0422\u04E9\u043B\u0435\u0433\u0435\u043D\u0433\u0435
        \u0434\u0438\u0434\u0430\u0440\u044B\u043D \u043A\u04E9\u0440\u0441\u0435\u0442\u0435\u0434\u0456."
      speakerName: "\u0410\u0432\u0442\u043E\u0440"
      characterSprite: {fileID: 21300000, guid: 2b3e98367c5cc934da5ceec9132a5ee8, type: 3}
      side: 0
    - sentence: "\u0416\u0456\u0431\u0435\u043A\u0442\u0456\u04A3 \u0441\u04B1\u043B\u0443\u043B\u044B\u0493\u044B\u043D\u0430
        \u0442\u0259\u043D\u0442\u0456 \u0431\u043E\u043B\u0493\u0430\u043D \u0422\u04E9\u043B\u0435\u0433\u0435\u043D
        \u043E\u043D\u044B\u043C\u0435\u043D \u0441\u04E9\u0437 \u049B\u0430\u0493\u044B\u0441\u0442\u044B\u0440\u044B\u043F,
        \u0441\u044B\u043D\u0430\u043F \u043A\u04E9\u0440\u0435\u0434\u0456. \u0416\u0456\u0431\u0435\u043A
        \u04E9\u0442\u043A\u0456\u0440 \u0442\u0456\u043B\u0434\u0456\u043B\u0456\u0433\u0456\u043C\u0435\u043D,
        \u043D\u0430\u043C\u044B\u0441\u0442\u044B\u043B\u044B\u0493\u044B\u043C\u0435\u043D
        \u043A\u04E9\u0440\u0456\u043D\u0435\u0434\u0456. \u0422\u04E9\u043B\u0435\u0433\u0435\u043D
        \u0416\u0456\u0431\u0435\u043A\u0442\u0456\u04A3 \u0436\u04AF\u0440\u0435\u0433\u0456\u043D
        \u0436\u0430\u0443\u043B\u0430\u043F \u0430\u043B\u0443 \u04AF\u0448\u0456\u043D
        \u0421\u044B\u0440\u043B\u044B\u0431\u0430\u0439 \u0445\u0430\u043D\u0493\u0430
        \u0435\u043A\u0456 \u0436\u04AF\u0437 \u0436\u043E\u0440\u0493\u0430 \u0431\u0435\u0440\u0456\u043F,
        \u049B\u04B1\u0434\u0430 \u0442\u04AF\u0441\u0443\u0433\u0435 \u043A\u0435\u043B\u0456\u0441\u0456\u043C\u0456\u043D
        \u0430\u043B\u0430\u0434\u044B. \u0411\u0435\u043A\u0435\u0436\u0430\u043D
        \u0431\u0430\u0441\u0442\u0430\u0493\u0430\u043D \u049B\u044B\u0437\u0493\u0430\u043D\u0448\u0430\u049B
        \u0436\u0456\u0433\u0456\u0442\u0442\u0435\u0440 \u0422\u04E9\u043B\u0435\u0433\u0435\u043D\u0433\u0435
        \u049B\u0430\u0441\u0442\u0430\u043D\u0434\u044B\u049B \u0436\u0430\u0441\u0430\u043C\u0430\u049B
        \u0431\u043E\u043B\u0493\u0430\u043D\u0434\u0430, \u049A\u0430\u0440\u0448\u044B\u0493\u0430
        \u043E\u043D\u044B \u0430\u043C\u0430\u043D \u0430\u043B\u044B\u043F \u049B\u0430\u043B\u044B\u043F,
        \u0441\u0435\u043D\u0456\u043C\u0434\u0456 \u0434\u043E\u0441\u044B \u0416\u0438\u0440\u0435\u043D\u0431\u0430\u0439\u0434\u044B\u04A3
        \u04AF\u0439\u0456\u043D\u0435 \u2013 \u0436\u0430\u04A3\u0430 \u043E\u0442\u0430\u0443\u0493\u0430
        \u0436\u0430\u0441\u044B\u0440\u0430\u0434\u044B. "
      speakerName: "\u0410\u0432\u0442\u043E\u0440"
      characterSprite: {fileID: 21300000, guid: 438ad63de2e3f4c4b86cbf8aef7e1bd4, type: 3}
      side: 1
  storyManager: {fileID: 474981830}
