--- !u!114 &2046434876
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2046434874}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 157a3517668cfd940b7f9d85d2eaae44, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    lines:
    - sentence: "\u0421\u043E\u043B \u0441\u0259\u0442\u0442\u0435\u043D \u0431\u0430\u0441\u0442\u0430\u043F
        \u0434\u043E\u043C\u0431\u044B\u0440\u0430\u043D\u044B\u04A3 \u0448\u0430\u043D\u0430\u0493\u044B\u043D\u0434\u0430
        \u049B\u0430\u0441\u0438\u0435\u0442\u0442\u0456 \"\u043A\u04E9\u043C\u0435\u0439\"
        \u043F\u0430\u0439\u0434\u0430 \u0431\u043E\u043B\u0434\u044B. \u049A\u0430\u0442\u0430\u043B 
        \u0445\u0430\u043D\u043D\u044B\u04A3 \u049B\u0430\u04BB\u0430\u0440\u044B\u043D\u0430\u043D
        \u049B\u043E\u0440\u044B\u049B\u043F\u0430\u0493\u0430\u043D \u04E9\u043D\u0435\u0440
        \u0448\u044B\u043D\u0434\u044B\u049B\u0442\u044B \u043E\u0441\u044B\u043B\u0430\u0439\u0448\u0430
        \u0436\u0435\u0442\u043A\u0456\u0437\u0433\u0435\u043D \u0435\u043A\u0435\u043D. 
        \u0411\u0430\u043B\u049B\u044B\u0493\u0430\u043D \u049B\u043E\u0440\u0493\u0430\u0441\u044B\u043D
        \u0430\u0441\u043F\u0430\u043F\u0442\u044B\u04A3 \u04AF\u043D\u0456\u043D
        \u04E9\u0448\u0456\u0440\u0435 \u0430\u043B\u043C\u0430\u0434\u044B, \u043A\u0435\u0440\u0456\u0441\u0456\u043D\u0448\u0435,
        \u043E\u0493\u0430\u043D \u0436\u0430\u043D \u0431\u0456\u0442\u0456\u0440\u0434\u0456.
        \u0421\u043E\u0434\u0430\u043D  \u0431\u0435\u0440\u0456 \u0434\u043E\u043C\u0431\u044B\u0440\u0430
        - \u049B\u0430\u0437\u0430\u049B\u0442\u044B\u04A3 \u0431\u0430\u0441\u044B\u043D\u0430\u043D
        \u043A\u0435\u0448\u043A\u0435\u043D \u049B\u0443\u0430\u043D\u044B\u0448\u044B
        \u043C\u0435\u043D \u049B\u0430\u0439\u0493\u044B\u0441\u044B\u043D \u0442\u0456\u043B\u0441\u0456\u0437 
        \u0431\u0430\u044F\u043D\u0434\u0430\u0439\u0442\u044B\u043D \u0445\u0430\u043B\u044B\u049B\u0442\u044B\u04A3
        \u049B\u0430\u0441\u0438\u0435\u0442\u0442\u0456 \u049B\u0430\u0437\u044B\u043D\u0430\u0441\u044B\u043D\u0430
        \u0430\u0439\u043D\u0430\u043B\u0434\u044B.  \u041A\u0435\u0442\u0431\u04B1\u0493\u0430
        \u0436\u044B\u0440\u0430\u0443\u0434\u044B\u04A3 \u043A\u04AF\u0439\u0456
        - \u04E9\u043B\u043C\u0435\u0441 \u04E9\u043D\u0435\u0440\u0434\u0456\u04A3,
        \u0430\u043B \u0434\u043E\u043C\u0431\u044B\u0440\u0430\u043D\u044B\u04A3
        \u043A\u04E9\u043C\u0435\u0439\u0456 - \u0448\u044B\u043D\u0434\u044B\u049B\u0442\u044B\u04A3 
        \u0441\u0438\u043C\u0432\u043E\u043B\u044B \u0431\u043E\u043B\u044B\u043F
        \u049B\u0430\u043B\u0434\u044B"
      speakerName: "\u201C\u0425\u0430\u043D \u0436\u0430\u0440\u043B\u044B\u0493\u044B\u043D
        \u043E\u0440\u044B\u043D\u0434\u0430\u0443\u201D"
      characterSprite: {fileID: 0}
      side: 0
  storyManager: {fileID: 2076816506}
