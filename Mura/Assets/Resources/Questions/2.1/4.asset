  _info: "\u0411\u0435\u043A\u0435\u0436\u0430\u043D \u0422\u04E9\u043B\u0435\u0433\u0435\u043D\u0434\u0456
    \u04E9\u043B\u0442\u0456\u0440\u0456\u043F, \u0430\u0442\u044B\u043D \u0430\u043B\u044B\u043F
    \u043A\u0435\u043B\u0433\u0435\u043D\u0434\u0435, \u0416\u0456\u0431\u0435\u043A
    \xAB\u0416\u043E\u049B\u0442\u0430\u0443\xBB \u0430\u0439\u0442\u0430\u0434\u044B.
    \u041E\u043B \u0441\u043E\u043B  \u0441\u0259\u0442\u0442\u0435 \u0416\u0430\u0440\u0430\u0442\u0443\u0448\u044B\u0434\u0430\u043D
