  m_Script: {fileID: 11500000, guid: 12650b1558e7fc7409fcf331f13d287b, type: 3}
  m_Name: 4
  m_EditorClassIdentifier: 
  _info: "\u0411\u0430\u044F\u043D\u043D\u044B\u04A3 \u049A\u043E\u0434\u0430\u0440\u0493\u0430
    \xAB\u049B\u04B1\u0434\u044B\u049B \u049B\u0430\u0437\u0434\u044B\u0440\u0443\u044B\xBB
    \u0442\u0435\u043A \u043A\u0435\u043A \u0430\u043B\u0443 \u0435\u043C\u0435\u0441,
    \u0441\u0438\u043C\u0432\u043E\u043B\u0434\u044B\u049B  \u043C\u0430\u0493\u044B\u043D\u0430\u0434\u0430
    \u043D\u0435\u043D\u0456 \u0431\u0456\u043B\u0434\u0456\u0440\u0435\u0434\u0456?"
  _answers:
  - _info: "\u049A\u043E\u0434\u0430\u0440\u0434\u044B\u04A3 \u043A\u04AF\u0448\u0456\u043D
      \u0441\u044B\u043D\u0430\u043F, \u043E\u043D\u044B\u04A3 \u0448\u0430\u0440\u0448\u0430\u0493\u0430\u043D\u044B\u043D
      \u043A\u04AF\u0442\u0443."
    _isCorrect: 0
  - _info: "\u041E\u043D\u044B \u0436\u0435\u0440 \u0430\u0441\u0442\u044B\u043D\u0430
      - \u049A\u043E\u0437\u044B \u0436\u0456\u0431\u0435\u0440\u0456\u043B\u0433\u0435\u043D
      \u04E9\u043B\u0456\u043C \u0259\u043B\u0435\u043C\u0456\u043D\u0435 \u0436\u0430\u049B\u044B\u043D\u0434\u0430\u0442\u044B\u043F,
      \u04E9\u0437 \u049B\u043E\u043B\u044B\u043C\u0435\u043D \u04E9\u0437  \xAB\u043A\u04E9\u0440\u0456\u043D\xBB
      \u049B\u0430\u0437\u0434\u044B\u0440\u0443. "
    _isCorrect: 1
  - _info: "\u0410\u0443\u044B\u043B\u0434\u044B \u0441\u0443\u043C\u0435\u043D \u049B\u0430\u043C\u0442\u0430\u043C\u0430\u0441\u044B\u0437
      \u0435\u0442\u0456\u043F, \u0445\u0430\u043B\u044B\u049B\u0442\u044B\u04A3
      \u0430\u043B\u0493\u044B\u0441\u044B\u043D \u0430\u043B\u0443."
    _isCorrect: 0
  - _info: "\u049A\u043E\u0434\u0430\u0440\u0434\u044B \u0436\u04B1\u043C\u044B\u0441\u043F\u0435\u043D
      \u0430\u043B\u0434\u0430\u043D\u0434\u044B\u0440\u044B\u043F, \u049A\u043E\u0437\u044B\u043D\u044B
      \u0442\u0456\u0440\u0456\u043B\u0442\u0456\u043F \u0430\u043B\u0443\u0493\u0430
      \u0443\u0430\u049B\u044B\u0442 \u04B1\u0442\u0443. "
    _isCorrect: 0
  _useTimer: 0
  _timer: 0
  _answerType: 1
  _addScore: 10
