  m_Script: {fileID: 11500000, guid: 12650b1558e7fc7409fcf331f13d287b, type: 3}
  m_Name: 2
  m_EditorClassIdentifier: 
  _info: "\u049A\u0430\u0440\u0430\u0431\u0430\u0439\u0434\u044B\u04A3 \u0441\u0435\u0440\u0442\u0456\u043D\u0435\u043D
    \u0442\u0430\u044E\u044B \u043E\u043D\u044B\u04A3 \u0442\u0435\u043A \u0431\u0430\u0439\u043B\u044B\u0493\u044B\u043D\u0430
    \u0493\u0430\u043D\u0430 \u0435\u043C\u0435\u0441, \u0442\u0430\u0493\u044B \u049B\u0430\u043D\u0434\u0430\u0439 
    \u0456\u0448\u043A\u0456 \u049B\u043E\u0440\u049B\u044B\u043D\u044B\u0448\u044B\u043D\u0430
    \u0431\u0430\u0439\u043B\u0430\u043D\u044B\u0441\u0442\u044B \u0431\u043E\u043B\u0443\u044B
    \u043C\u04AF\u043C\u043A\u0456\u043D?"
  _answers:
  - _info: "\u049A\u043E\u0437\u044B\u043D\u044B\u04A3 \u043A\u0435\u0434\u0435\u0439
      \u0431\u043E\u043B\u044B\u043F \u04E9\u0441\u043A\u0435\u043D\u0456\u043D\u0435
      \u0436\u0259\u043D\u0435 \u04E9\u0437 \u0259\u0443\u043B\u0435\u0442\u0456\u043D\u0456\u04A3
      \u0259\u043B\u0435\u0443\u043C\u0435\u0442\u0442\u0456\u043A \u043C\u0259\u0440\u0442\u0435\u0431\u0435\u0441\u0456\u043D\u0456\u04A3
      \u0442\u04AF\u0441\u0443\u0456\u043D\u0435  \u0434\u0435\u0433\u0435\u043D
      \u049B\u043E\u0440\u049B\u044B\u043D\u044B\u0448."
    _isCorrect: 1
  - _info: "\u049A\u043E\u0434\u0430\u0440\u0434\u044B\u04A3 \u043E\u0493\u0430\u043D
      \u043A\u04E9\u0440\u0441\u0435\u0442\u043A\u0435\u043D \u0444\u0438\u0437\u0438\u043A\u0430\u043B\u044B\u049B
      \u049B\u044B\u0441\u044B\u043C\u044B \u043C\u0435\u043D \u049B\u043E\u049B\u0430\u043D-\u043B\u043E\u049B\u044B\u0441\u044B. "
    _isCorrect: 0
  - _info: " \u0411\u0430\u044F\u043D\u043D\u044B\u04A3 \u049A\u043E\u0437\u044B\u043D\u044B
      \u0435\u0448\u049B\u0430\u0448\u0430\u043D \u0436\u0430\u049B\u0441\u044B \u043A\u04E9\u0440\u043C\u0435\u0439\u0442\u0456\u043D\u0456\u043D\u0435
      \u0441\u0435\u043D\u0456\u043C\u0434\u0456 \u0431\u043E\u043B\u0443\u044B."
    _isCorrect: 0
  - _info: "\u0421\u0430\u0440\u044B\u0431\u0430\u0439\u0434\u044B\u04A3 \u0440\u0443\u044B\u043D\u0430\u043D
      \u043A\u0435\u043B\u0435\u0442\u0456\u043D \u0435\u0436\u0435\u043B\u0433\u0456
      \u049B\u0430\u0440\u0493\u044B\u0441\u0442\u0430\u043D \u049B\u0430\u0448\u0443\u044B."
    _isCorrect: 0
