  m_Script: {fileID: 11500000, guid: 12650b1558e7fc7409fcf331f13d287b, type: 3}
  m_Name: 1
  m_EditorClassIdentifier: 
  _info: "\u0421\u0430\u0440\u044B\u0431\u0430\u0439 \u043C\u0435\u043D \u049A\u0430\u0440\u0430\u0431\u0430\u0439\u0434\u044B\u04A3
    \xAB\u0431\u0435\u043B \u049B\u04B1\u0434\u0430\xBB \u0431\u043E\u043B\u0443\u044B
    \u0442\u0435\u043A \u0434\u043E\u0441\u0442\u044B\u049B \u0435\u043C\u0435\u0441,
    \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044F\u043B\u044B\u049B  \u049B\u0430\u0434\u0430\u043C
    \u0431\u043E\u043B\u0434\u044B \u0434\u0435\u0441\u0435\u043A, \u0431\u04B1\u043B
    \u049B\u0430\u0437\u0430\u049B \u0442\u04AF\u0441\u0456\u043D\u0456\u0433\u0456\u043D\u0434\u0435
    \u043D\u0435\u043D\u0456 \u0431\u0456\u043B\u0434\u0456\u0440\u0434\u0456? "
  _answers:
  - _info: "\u0415\u043A\u0456 \u0431\u0430\u0439\u0434\u044B\u04A3 \u043C\u0430\u043B-\u043C\u04AF\u043B\u043A\u0456\u043D
      \u0442\u0435\u0437\u0456\u0440\u0435\u043A \u0431\u0456\u0440\u0456\u043A\u0442\u0456\u0440\u0443
      \u049B\u04B1\u0440\u0430\u043B\u044B."
    _isCorrect: 0
  - _info: "\u0411\u043E\u043B\u0430\u0448\u0430\u049B\u0442\u0430 \u0442\u0443\u044B\u043B\u0443\u044B
      \u043C\u04AF\u043C\u043A\u0456\u043D \u0436\u0430\u0443\u043B\u0430\u0441\u0442\u044B\u049B\u0442\u044B\u04A3
      \u0430\u043B\u0434\u044B\u043D \u0430\u043B\u044B\u043F, \u0440\u0443\u043B\u0430\u0440
      \u0430\u0440\u0430\u0441\u044B\u043D\u0434\u0430\u0493\u044B  \u0442\u04B1\u0440\u0430\u049B\u0442\u044B\u043B\u044B\u049B\u0442\u044B
      \u0431\u0435\u043A\u0456\u0442\u0443."
    _isCorrect: 1
  - _info: "\u0411\u0430\u043B\u0430\u043B\u0430\u0440\u0434\u044B\u04A3 \u0431\u0456\u043B\u0456\u043C\u0456\u043D
      \u0430\u0440\u0442\u0442\u044B\u0440\u0443 \u04AF\u0448\u0456\u043D \u0436\u0430\u0441\u0430\u043B\u0493\u0430\u043D
      \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u043A\u0430\u043B\u044B\u049B
      \u0259\u0434\u0456\u0441."
    _isCorrect: 0
  - _info: "\u0421\u0430\u0440\u044B\u0431\u0430\u0439\u0434\u044B\u04A3 \u04E9\u043B\u0456\u043C\u0456\u043D
      \u0430\u043B\u0434\u044B\u043D \u0430\u043B\u0430 \u0431\u043E\u043B\u0436\u0430\u043F,
      \u043E\u043D\u044B\u04A3 \u043E\u0442\u0431\u0430\u0441\u044B\u043D\u0430 \u043A\u04E9\u043C\u0435\u043A\u0442\u0435\u0441\u0443
      \u0436\u043E\u0441\u043F\u0430\u0440\u044B."
    _isCorrect: 0
