  m_Script: {fileID: 11500000, guid: 12650b1558e7fc7409fcf331f13d287b, type: 3}
  m_Name: 3
  m_EditorClassIdentifier: 
  _info: "\u049A\u043E\u0437\u044B \u043C\u0435\u043D \u0411\u0430\u044F\u043D \u0431\u0456\u0440-\u0431\u0456\u0440\u0456\u043D
    \u043A\u04E9\u0440\u043C\u0435\u0439 \u0442\u04B1\u0440\u044B\u043F \u043D\u0435\u043B\u0456\u043A\u0442\u0435\u043D
    \u049B\u0430\u0442\u0442\u044B \u0436\u0430\u049B\u0441\u044B \u043A\u04E9\u0440\u0434\u0456?
    \u0411\u04B1\u043B  \u0436\u0435\u0440\u0434\u0435\u0433\u0456 \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u044F\u043B\u044B\u049B
    \u0444\u0430\u043A\u0442\u043E\u0440 \u049B\u0430\u043D\u0434\u0430\u0439?"
  _answers:
  - _info: "\u041E\u043B\u0430\u0440\u0434\u044B\u04A3 \u0442\u04AF\u0441\u0456\u043D\u0435
      \u04AF\u043D\u0435\u043C\u0456 \u0431\u0456\u0440-\u0431\u0456\u0440\u0456
      \u043A\u0456\u0440\u0456\u043F, \u0430\u044F\u043D \u0431\u0435\u0440\u0433\u0435\u043D\u0434\u0456\u043A\u0442\u0435\u043D."
    _isCorrect: 0
  - _info: "\u0415\u043A\u0435\u0443\u0456 \u0434\u0435 \u0435\u0440\u0442\u0435\u0433\u0456\u043B\u0435\u0440
      \u043C\u0435\u043D \u0430\u04A3\u044B\u0437\u0434\u0430\u0440\u0434\u044B \u043A\u04E9\u043F
      \u0442\u044B\u04A3\u0434\u0430\u0493\u0430\u043D\u0434\u044B\u049B\u0442\u0430\u043D."
    _isCorrect: 0
  - _info: "\xAB\u0410\u043C\u0430\u043D\u0430\u0442\xBB \u043F\u0435\u043D \xAB\u0442\u0430\u0493\u0434\u044B\u0440\xBB
      \u04B1\u0493\u044B\u043C\u044B\u043D\u0430 \u0434\u0435\u0433\u0435\u043D \u0441\u0435\u043D\u0456\u043C
      \u0436\u0259\u043D\u0435 \u0430\u0439\u043D\u0430\u043B\u0430\u0441\u044B\u043D\u0434\u0430\u0493\u044B\u043B\u0430\u0440\u0434\u0430\u043D
      \u0435\u0441\u0442\u0456\u0433\u0435\u043D  \u0438\u0434\u0435\u0430\u043B\u0434\u044B
      \u0431\u0435\u0439\u043D\u0435\u0433\u0435 \u0493\u0430\u0448\u044B\u049B \u0431\u043E\u043B\u0443. "
    _isCorrect: 1
  - _info: "\u041E\u043B\u0430\u0440 \u0436\u0430\u0441\u044B\u0440\u044B\u043D \u0445\u0430\u0442
      \u0430\u043B\u043C\u0430\u0441\u044B\u043F, \u0441\u0443\u0440\u0435\u0442\u0442\u0435\u0440\u0456\u043D
      \u0431\u0456\u0440-\u0431\u0456\u0440\u0456\u043D\u0435 \u0436\u0456\u0431\u0435\u0440\u0456\u043F
      \u043E\u0442\u044B\u0440\u0493\u0430\u043D\u0434\u044B\u049B\u0442\u0430\u043D."
    _isCorrect: 0
  _useTimer: 0
  _timer: 0
  _answerType: 1
  _addScore: 10
