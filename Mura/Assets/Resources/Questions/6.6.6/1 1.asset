  m_Script: {fileID: 11500000, guid: 12650b1558e7fc7409fcf331f13d287b, type: 3}
  m_Name: 1 1
  m_EditorClassIdentifier: 
  _info: "\u0428\u043E\u0440\u0442\u0430\u043D\u0431\u0430\u0439 \u049A\u0430\u043D\u0430\u0439\u04B1\u043B\u044B\u043D\u044B\u04A3
    \xAB\u041E\u0440\u044B\u0441 \u2013 \u0431\u04AF\u0440\u043A\u0456\u0442, \u0431\u0456\u0437
    \u2013 \u0442\u04AF\u043B\u043A\u0456\xBB \u0434\u0435\u0433\u0435\u043D \u0442\u0435\u04A3\u0435\u0443\u0456 
    \u043E\u0442\u0430\u0440\u043B\u0430\u0443\u0448\u044B \u043C\u0435\u043D \u043E\u0442\u0430\u0440\u043B\u0430\u043D\u0443\u0448\u044B
    \u0430\u0440\u0430\u0441\u044B\u043D\u0434\u0430\u0493\u044B \u049B\u0430\u043D\u0434\u0430\u0439
    \u049B\u0430\u0442\u044B\u043D\u0430\u0441\u0442\u044B \u0431\u0435\u0439\u043D\u0435\u043B\u0435\u0439\u0434\u0456? "
  _answers:
  - _info: "\u0422\u0430\u0431\u0438\u0493\u0430\u0442 \u043F\u0435\u043D \u0430\u0434\u0430\u043C\u043D\u044B\u04A3
      \u04E9\u0437\u0430\u0440\u0430 \u0442\u0435\u043F\u0435-\u0442\u0435\u04A3\u0434\u0456\u0433\u0456\u043D."
    _isCorrect: 0
  - _info: "\u0415\u043A\u0456 \u0445\u0430\u043B\u044B\u049B\u0442\u044B\u04A3 \u0430\u0440\u0430\u0441\u044B\u043D\u0434\u0430\u0493\u044B
      \u0434\u043E\u0441\u0442\u044B\u049B \u043F\u0435\u043D \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442\u0438\u044F\u043B\u044B\u049B
      \u0431\u0430\u0439\u043B\u0430\u043D\u044B\u0441\u0442\u044B."
    _isCorrect: 0
  - _info: "\u041A\u04AF\u0448\u0442\u0456\u043D\u0456\u04A3 \u0259\u043B\u0441\u0456\u0437\u0434\u0456
      \u0435\u0440\u0456\u043A\u0441\u0456\u0437 \u0431\u0430\u0493\u044B\u043D\u0434\u044B\u0440\u0443\u044B
      \u043C\u0435\u043D \u0430\u0439\u043B\u0430\u043B\u044B \u043E\u0442\u0430\u0440\u043B\u0430\u0443
      \u0441\u0430\u044F\u0441\u0430\u0442\u044B\u043D."
    _isCorrect: 1
  - _info: "\u049A\u0430\u0437\u0430\u049B \u0445\u0430\u043B\u049B\u044B\u043D\u044B\u04A3
      \u0430\u04A3\u0448\u044B\u043B\u044B\u049B \u04E9\u043D\u0435\u0440\u0456\u043D\u0435
      \u0434\u0435\u0433\u0435\u043D \u049B\u04B1\u0448\u0442\u0430\u0440\u043B\u044B\u0493\u044B\u043D."
    _isCorrect: 0
