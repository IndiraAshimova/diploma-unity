  m_Script: {fileID: 11500000, guid: 12650b1558e7fc7409fcf331f13d287b, type: 3}
  m_Name: 1 3
  m_EditorClassIdentifier: 
  _info: "\u041C\u0259\u0442\u0456\u043D\u0434\u0435\u0433\u0456 \xAB\u0415\u0440\u0443\u043B\u0456\u043A\u0441\u0456\u0437
    \u049B\u0430\u043B\u0493\u0430\u043D \u0430\u0443\u044B\u043B\xBB \u0431\u0435\u0439\u043D\u0435\u0441\u0456
    \u043D\u0435\u043D\u0456\u04A3 \u0441\u0438\u043C\u0432\u043E\u043B\u044B \u0431\u043E\u043B\u044B\u043F
    \u0442\u0430\u0431\u044B\u043B\u0430\u0434\u044B?"
  _answers:
  - _info: "\u041A\u04E9\u0448 \u0436\u043E\u043B\u0434\u0430\u0440\u044B\u043D\u044B\u04A3
      \u0436\u0430\u0431\u044B\u043B\u0443\u044B \u0436\u0259\u043D\u0435 \u0435\u043B
      \u0456\u0448\u0456\u043D\u0434\u0435\u0433\u0456 \u0431\u0430\u0443\u044B\u0440\u043C\u0430\u043B\u0434\u044B\u049B
      \u043F\u0435\u043D \u0431\u0456\u0440\u043B\u0456\u043A\u0442\u0456\u04A3 \u04AF\u0437\u0456\u043B\u0443\u0456."
    _isCorrect: 1
  - _info: "\u0425\u0430\u043B\u044B\u049B\u0442\u044B\u04A3 \u0431\u0430\u0439\u044B\u043F,
      \u049B\u043E\u043D\u0430\u049B\u0436\u0430\u0439\u043B\u044B\u043B\u044B\u049B
      \u043A\u04E9\u0440\u0441\u0435\u0442\u0443\u0434\u0456 \u049B\u0430\u0436\u0435\u0442
      \u0435\u0442\u043F\u0435\u0443\u0456."
    _isCorrect: 0
  - _info: "\u0416\u0430\u04A3\u0430 \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u044F\u043B\u0430\u0440\u0434\u044B\u04A3
      \u043A\u0435\u043B\u0443\u0456\u043C\u0435\u043D \u0435\u0441\u043A\u0456 \u0441\u0430\u043B\u0442\u0442\u0430\u0440\u0434\u044B\u04A3
      \u04E9\u0437\u0434\u0456\u0433\u0456\u043D\u0435\u043D \u0436\u043E\u0439\u044B\u043B\u0443\u044B."
    _isCorrect: 0
  - _info: "\u0410\u0443\u044B\u043B\u0434\u0430\u0440\u0434\u044B\u04A3 \u0431\u0456\u0440\u0456\u0433\u0456\u043F,
      \u0456\u0440\u0456 \u049B\u0430\u043B\u0430\u043B\u0430\u0440\u0493\u0430 \u0430\u0439\u043D\u0430\u043B\u0443\u044B."
    _isCorrect: 0
  _useTimer: 0
  _timer: 0
  _answerType: 1
  _addScore: 10
