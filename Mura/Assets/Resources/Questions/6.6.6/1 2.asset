  _info: "\u0422\u043E\u043B\u0493\u0430\u0443 \u0431\u043E\u0439\u044B\u043D\u0448\u0430,
    \xAB\u0417\u0430\u0440 \u0437\u0430\u043C\u0430\u043D\u043D\u044B\u04A3\xBB \u0431\u0430\u0441\u0442\u044B
    \u0431\u0435\u043B\u0433\u0456\u0441\u0456 \u0440\u0435\u0442\u0456\u043D\u0434\u0435
    \u0430\u0442\u0430\u043B\u0493\u0430\u043D \xAB\u0430\u0434\u0430\u043C\u043D\u044B\u04A3 
    \u0430\u0437\u0443\u044B\xBB \u0434\u0435\u0433\u0435\u043D\u0434\u0456 \u049B\u0430\u043B\u0430\u0439
    \u0442\u04AF\u0441\u0456\u043D\u0443\u0433\u0435 \u0431\u043E\u043B\u0430\u0434\u044B? "
  _answers:
  - _info: "\u0425\u0430\u043B\u044B\u049B\u0442\u044B\u04A3 \u0436\u0430\u043F\u043F\u0430\u0439
      \u043A\u0435\u0434\u0435\u0439\u043B\u0435\u043D\u0456\u043F, \u0430\u0448\u0430\u0440\u0448\u044B\u043B\u044B\u049B\u049B\u0430
      \u04B1\u0448\u044B\u0440\u0430\u0443\u044B."
    _isCorrect: 0
  - _info: "\u0414\u0259\u0441\u0442\u04AF\u0440\u043B\u0456 \u0438\u043C\u0430\u043D\u043D\u044B\u04A3,
      \u0259\u0434\u0435\u043F\u0442\u0456\u04A3 \u0436\u0259\u043D\u0435 \u0430\u0493\u0430\u0439\u044B\u043D
      \u0430\u0440\u0430\u0441\u044B\u043D\u0434\u0430\u0493\u044B \u0431\u0430\u0443\u044B\u0440\u043C\u0430\u043B\u0434\u044B\u049B\u0442\u044B\u04A3
      \u0436\u043E\u0493\u0430\u043B\u0443\u044B."
    _isCorrect: 1
  - _info: "\u0416\u0430\u0441\u0442\u0430\u0440\u0434\u044B\u04A3 \u0436\u0430\u043F\u043F\u0430\u0439
      \u0435\u0433\u0456\u043D \u0448\u0430\u0440\u0443\u0430\u0448\u044B\u043B\u044B\u0493\u044B\u043D\u0430
      \u043A\u04E9\u0448\u0443\u0456.  "
    _isCorrect: 0
  - _info: "\u0411\u0430\u0439\u043B\u0430\u0440\u0434\u044B\u04A3 \u043C\u0430\u043B
      \u0441\u0430\u043D\u044B\u043D \u0430\u0437\u0430\u0439\u0442\u044B\u043F,
      \u0430\u049B\u0448\u0430 \u0436\u0438\u043D\u0430\u0443\u0493\u0430 \u043A\u04E9\u0448\u0443\u0456."
    _isCorrect: 0
