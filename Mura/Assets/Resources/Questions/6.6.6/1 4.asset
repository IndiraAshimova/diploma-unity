  m_Script: {fileID: 11500000, guid: 12650b1558e7fc7409fcf331f13d287b, type: 3}
  m_Name: 1 4
  m_EditorClassIdentifier: 
  _info: "\u041C\u0259\u0442\u0456\u043D\u0433\u0435 \u0441\u04AF\u0439\u0435\u043D\u0441\u0435\u043A,
    \xAB\u0417\u0430\u0440 \u0437\u0430\u043C\u0430\u043D\xBB \u0430\u0493\u044B\u043C\u044B\u043D\u044B\u04A3
    \u043D\u0435\u0433\u0456\u0437\u0433\u0456 \u0438\u0434\u0435\u044F\u043B\u044B\u049B
    \u043C\u0430\u0437\u043C\u04B1\u043D\u044B \u049B\u0430\u043D\u0434\u0430\u0439?"
  _answers:
  - _info: "\u0416\u0430\u04A3\u0430 \u0437\u0430\u043C\u0430\u043D \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u043B\u0430\u0440\u044B\u043D
      \u049B\u043E\u043B\u0434\u0430\u043F, \u0435\u0443\u0440\u043E\u043F\u0430\u043B\u044B\u049B
      \u0431\u0456\u043B\u0456\u043C\u0434\u0456 \u043D\u0430\u0441\u0438\u0445\u0430\u0442\u0442\u0430\u0443."
    _isCorrect: 0
  - _info: "\u041A\u04E9\u0448\u043F\u0435\u043B\u0456 \u04E9\u043C\u0456\u0440\u0434\u0435\u043D
      \u0433\u04E9\u0440\u0456 \u043E\u0442\u044B\u0440\u044B\u049B\u0448\u044B\u043B\u044B\u049B\u0442\u044B\u04A3
      \u0430\u0440\u0442\u044B\u049B\u0448\u044B\u043B\u044B\u0493\u044B\u043D \u0434\u0259\u043B\u0435\u043B\u0434\u0435\u0443."
    _isCorrect: 0
  - _info: "\u0422\u0435\u043A \u049B\u0430\u043D\u0430 \u0434\u0456\u043D\u0438
      \u043D\u0430\u043D\u044B\u043C-\u0441\u0435\u043D\u0456\u043C\u0434\u0435\u0440\u0434\u0456
      \u049B\u043E\u0440\u0493\u0430\u043F, \u0441\u0430\u044F\u0441\u0430\u0442\u049B\u0430
      \u0430\u0440\u0430\u043B\u0430\u0441\u043F\u0430\u0443."
    _isCorrect: 0
  - _info: "\u0416\u043E\u0493\u0430\u043B\u0493\u0430\u043D \u0435\u0440\u043A\u0456\u043D\u0434\u0456\u043A\u0442\u0456
      \u0430\u04A3\u0441\u0430\u0443, \u043E\u0442\u0430\u0440\u043B\u0430\u0443\u0434\u044B\u04A3
      \u049B\u0430\u0441\u0456\u0440\u0435\u0442\u0456\u043D \u0436\u044B\u0440\u043B\u0430\u0443
      \u0436\u0259\u043D\u0435 \u04B1\u043B\u0442\u0442\u044B\u049B \u043A\u043E\u0434\u0442\u044B\u04A3 
      \u0431\u04B1\u0437\u044B\u043B\u0443\u044B\u043D\u0430 \u043D\u0430\u043B\u0443. "
    _isCorrect: 1
  _useTimer: 0
  _timer: 0
