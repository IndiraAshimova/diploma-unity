  m_Name: 4
  m_EditorClassIdentifier: 
  _info: "\u041A\u0435\u0442\u0431\u04B1\u0493\u0430 \u0436\u044B\u0440\u0430\u0443\u0434\u044B\u04A3
    \xAB\u0416\u0430\u0437\u044B\u0493\u044B\u043C \u043C\u044B\u043D\u0430 \u0434\u043E\u043C\u0431\u044B\u0440\u0430
    \u0435\u043C\u0435\u0441 \u043F\u0435?\xBB \u0434\u0435\u0433\u0435\u043D \u0441\u04E9\u0437\u0456\u043D\u0456\u04A3 
    \u0430\u0441\u0442\u0430\u0440\u044B\u043D\u0434\u0430 \u049B\u0430\u043D\u0434\u0430\u0439
    \u049B\u0443\u043B\u044B\u049B \u043D\u0435\u043C\u0435\u0441\u0435 \u0434\u0430\u043D\u0430\u043B\u044B\u049B
    \u0436\u0430\u0442\u044B\u0440?"
  _answers:
  - _info: "\u04E8\u0437 \u0436\u0430\u043D\u044B\u043D \u0441\u0430\u049B\u0442\u0430\u043F
      \u049B\u0430\u043B\u0443 \u04AF\u0448\u0456\u043D \u0430\u0441\u043F\u0430\u043F\u0442\u044B
      \u049B\u04B1\u0440\u0431\u0430\u043D \u0435\u0442\u0443."
    _isCorrect: 0
  - _info: "\u0425\u0430\u043D\u043D\u044B\u04A3 \u0436\u0430\u0440\u043B\u044B\u0493\u044B\u043D\u0434\u0430\u0493\u044B
      \xAB\u0445\u0430\u0431\u0430\u0440\u0434\u044B \u0435\u0441\u0442\u0456\u0440\u0442\u043A\u0435\u043D\u043D\u0456\u04A3
      \u043A\u04E9\u043C\u0435\u0439\u0456\u043D\u0435\xBB \u0434\u0435\u0433\u0435\u043D
      \u0441\u04E9\u0437\u0434\u0456 \u0448\u0435\u0431\u0435\u0440  \u043F\u0430\u0439\u0434\u0430\u043B\u0430\u043D\u044B\u043F,
      \u04E9\u043D\u0435\u0440\u0434\u0456 \u0430\u043B\u0493\u0430 \u0448\u044B\u0493\u0430\u0440\u0443. "
    _isCorrect: 1
  - _info: "\u0414\u043E\u043C\u0431\u044B\u0440\u0430\u043D\u044B\u04A3 \u0441\u0430\u043F\u0430\u0441\u044B\u0437
      \u0435\u043A\u0435\u043D\u0456\u043D \u0430\u0439\u0442\u049B\u044B\u0441\u044B
      \u043A\u0435\u043B\u0443\u0456."
    _isCorrect: 0
