  m_Name: 2
  m_EditorClassIdentifier: 
  _info: "\u0416\u043E\u0448\u044B \u0445\u0430\u043D\u043D\u044B\u04A3 \xAB\u0416\u0430\u0437\u0430\u043D\u044B
    \u0434\u043E\u043C\u0431\u044B\u0440\u0430 \u0442\u0430\u0440\u0442\u0441\u044B\u043D\xBB
    \u0434\u0435\u0433\u0435\u043D \u0448\u0435\u0448\u0456\u043C\u0456 \u043E\u043D\u044B\u04A3
    \u049B\u0430\u043D\u0434\u0430\u0439 \u0456\u0448\u043A\u0456  \u043A\u04AF\u0439\u0456\u043D
    \u043A\u04E9\u0440\u0441\u0435\u0442\u0435\u0434\u0456?"
  _answers:
  - _info: "\u041A\u04AF\u0439\u0448\u0456\u043D\u0456\u04A3 \u0430\u043B\u0434\u044B\u043D\u0434\u0430
      \u0436\u0435\u04A3\u0456\u043B\u0433\u0435\u043D\u0456\u043D \u043C\u043E\u0439\u044B\u043D\u0434\u0430\u0441\u0430
      \u0434\u0430, \u0445\u0430\u043D \u0440\u0435\u0442\u0456\u043D\u0434\u0435\u0433\u0456
      \u049B\u0430\u0442\u0430\u043B\u0434\u044B\u0493\u044B\u043D\u0430\u043D \u0431\u0430\u0441 
      \u0442\u0430\u0440\u0442\u0430 \u0430\u043B\u043C\u0430\u0443\u044B\u043D.  "
    _isCorrect: 1
  - _info: "\u0414\u043E\u043C\u0431\u044B\u0440\u0430\u043D\u044B \u0430\u0434\u0430\u043C\u043D\u0430\u043D
      \u0436\u043E\u0493\u0430\u0440\u044B \u049B\u043E\u0439\u0493\u0430\u043D\u044B\u043D."
    _isCorrect: 0
  - _info: "\u049A\u043E\u0440\u0493\u0430\u0441\u044B\u043D\u043D\u044B\u04A3 \u0430\u0434\u0430\u043C\u0493\u0430
      \u049B\u0430\u0440\u0430\u0493\u0430\u043D\u0434\u0430 \u0430\u0493\u0430\u0448\u049B\u0430
      \u043F\u0430\u0439\u0434\u0430\u043B\u044B \u0435\u043A\u0435\u043D\u0456\u043D
      \u0442\u04AF\u0441\u0456\u043D\u0443\u0456\u043D."
    _isCorrect: 0
