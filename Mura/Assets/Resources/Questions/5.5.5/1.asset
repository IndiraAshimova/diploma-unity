  _info: " \u041D\u0435\u043B\u0456\u043A\u0442\u0435\u043D \u0431\u0430\u043B\u049B\u044B\u0493\u0430\u043D
    \u049B\u043E\u0440\u0493\u0430\u0441\u044B\u043D \u0434\u043E\u043C\u0431\u044B\u0440\u0430\u043D\u044B\u04A3
    \u04AF\u043D\u0456\u043D \u04E9\u0448\u0456\u0440\u0443\u0434\u0456\u04A3 \u043E\u0440\u043D\u044B\u043D\u0430,
    \u043E\u0493\u0430\u043D \xAB\u0436\u0430\u043D  \u0431\u0456\u0442\u0456\u0440\u0434\u0456\xBB
    \u0434\u0435\u043F \u0430\u0439\u0442\u044B\u043B\u0430\u0434\u044B?"
  _answers:
  - _info: "\u049A\u043E\u0440\u0493\u0430\u0441\u044B\u043D \u0430\u0441\u043F\u0430\u043F\u0442\u044B\u04A3
      \u0434\u044B\u0431\u044B\u0441\u044B\u043D \u049B\u0430\u0442\u0442\u044B\u0440\u0430\u049B
      \u0448\u044B\u0493\u0430\u0440\u0493\u0430\u043D\u0434\u044B\u049B\u0442\u0430\u043D."
    _isCorrect: 0
  - _info: "\u04E8\u043D\u0435\u0440 \u0448\u044B\u043D\u0434\u044B\u049B\u043F\u0435\u043D
      \u04B1\u0448\u0442\u0430\u0441\u049B\u0430\u043D\u0434\u0430 \u0493\u0430\u043D\u0430
      \u0445\u0430\u043B\u044B\u049B\u0442\u044B\u04A3 \u043C\u0259\u04A3\u0433\u0456\u043B\u0456\u043A
      \u049B\u0430\u0437\u044B\u043D\u0430\u0441\u044B\u043D\u0430  \u0430\u0439\u043D\u0430\u043B\u0430\u0442\u044B\u043D\u044B\u043D
      \u0431\u0456\u043B\u0434\u0456\u0440\u0435\u0434\u0456."
    _isCorrect: 1
  - _info: "\u0414\u043E\u043C\u0431\u044B\u0440\u0430 \u0430\u0493\u0430\u0448\u044B
      \u043C\u044B\u049B\u0442\u044B \u0431\u043E\u043B\u0493\u0430\u043D\u0434\u044B\u049B\u0442\u0430\u043D
