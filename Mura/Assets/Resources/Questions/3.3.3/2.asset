  m_Script: {fileID: 11500000, guid: 12650b1558e7fc7409fcf331f13d287b, type: 3}
  m_Name: 2
  m_EditorClassIdentifier: 
  _info: " \xAB\u041F\u0430\u0442\u0448\u0430 \u0446\u0435\u043D\u0437\u0443\u0440\u0430\u0441\u044B
    \u049B\u0430\u0442\u0430\u043B. \u0411\u04B1\u043B \u043A\u0456\u0442\u0430\u043F\u0442\u044B
    \u049B\u0430\u0439 \u0436\u0435\u0440\u0434\u0435 \u0431\u0430\u0441\u044B\u043F 
    \u0448\u044B\u0493\u0430\u0440\u0441\u0430\u049B, \u0435\u043B\u0433\u0435 \u0442\u0435\u0437\u0456\u0440\u0435\u043A
    \u0436\u0435\u0442\u0435\u0434\u0456 \u0436\u0259\u043D\u0435 \u049B\u0430\u0443\u0456\u043F\u0441\u0456\u0437
    \u0431\u043E\u043B\u0430\u0434\u044B?\xBB"
  _answers:
  - _info: "\u049A\u0430\u0437\u0430\u043D \u049B\u0430\u043B\u0430\u0441\u044B\u043D\u0434\u0430,
      \u0431\u0430\u0443\u044B\u0440\u043B\u0430\u0441 \u0442\u0430\u0442\u0430\u0440
      \u0431\u0430\u0441\u043F\u0430\u0445\u0430\u043D\u0430\u0441\u044B\u043D\u0434\u0430."
    _isCorrect: 1
  - _info: " \u0412\u0435\u0440\u043D\u044B\u0439 (\u0410\u043B\u043C\u0430\u0442\u044B)
      \u0431\u0435\u043A\u0456\u043D\u0456\u0441\u0456\u043D\u0434\u0435, \u0433\u0435\u043D\u0435\u0440\u0430\u043B-\u0433\u0443\u0431\u0435\u0440\u043D\u0430\u0442\u043E\u0440\u0434\u044B\u04A3
      \u0430\u043B\u0434\u044B\u043D\u0434\u0430."
    _isCorrect: 0
  - _info: "\u0410\u0443\u044B\u043B \u0430\u0440\u0430\u0441\u044B\u043D\u0434\u0430,
      \u049B\u043E\u043B\u043C\u0435\u043D \u043A\u04E9\u0448\u0456\u0440\u0456\u043F
      \u0436\u0430\u0437\u0443 \u0430\u0440\u049B\u044B\u043B\u044B."
    _isCorrect: 0
