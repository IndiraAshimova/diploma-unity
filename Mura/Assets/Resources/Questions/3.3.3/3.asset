  m_EditorClassIdentifier: 
  _info: "\xAB\u0425\u0430\u043B\u049B\u044B\u043C\u043D\u044B\u04A3 \u0435\u04A3
    \u04AF\u043B\u043A\u0435\u043D \u049B\u0430\u0441\u0456\u0440\u0435\u0442\u0456
    \u043D\u0435 \u0431\u043E\u043B\u044B\u043F \u0442\u04B1\u0440? \u041E\u0441\u044B\u043D\u044B
    \u043A\u0456\u0442\u0430\u043F\u0442\u044B\u04A3  \u04E9\u0437\u0435\u0433\u0456
    \u0440\u0435\u0442\u0456\u043D\u0434\u0435 \u0436\u0430\u0437\u0443\u044B\u043C
    \u043A\u0435\u0440\u0435\u043A...\xBB"
  _answers:
  - _info: "\u0416\u0435\u0440 \u043C\u0259\u0441\u0435\u043B\u0435\u0441\u0456,
      \u043D\u0430\u0434\u0430\u043D\u0434\u044B\u049B \u0436\u0259\u043D\u0435 \u043E\u0442\u0430\u0440\u043B\u0430\u0443
      \u0441\u0430\u044F\u0441\u0430\u0442\u044B. "
    _isCorrect: 1
  - _info: "\u0422\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u044F\u043D\u044B\u04A3
      \u0436\u043E\u049B\u0442\u044B\u0493\u044B \u0436\u0259\u043D\u0435 \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442\u0442\u0456\u04A3
      \u0431\u043E\u043B\u043C\u0430\u0443\u044B."
    _isCorrect: 0
  - _info: "\u041A\u04E9\u0440\u0448\u0456 \u0435\u043B\u0434\u0435\u0440\u043C\u0435\u043D
      \u0441\u0430\u0443\u0434\u0430-\u0441\u0430\u0442\u0442\u044B\u049B\u0442\u044B\u04A3
      \u043D\u0430\u0448\u0430\u0440\u043B\u044B\u0493\u044B. "
    _isCorrect: 0
