    _isCorrect: 0
  - _info: "\xAB\u041A\u04E9\u0437\u0456\u04A3\u0434\u0456 \u0430\u0448, \u043E\u044F\u043D,
      \u049B\u0430\u0437\u0430\u049B, \u043A\u04E9\u0442\u0435\u0440 \u0431\u0430\u0441\u0442\u044B...\xBB "
