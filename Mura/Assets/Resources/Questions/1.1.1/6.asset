  _info: "4)\u0415\u0440\u0442\u04E9\u0441\u0442\u0456\u043A\u0442\u0456\u04A3 \u0436\u0430\u0443\u044B\u043D
    \u0436\u0435\u04A3\u0443 \u04AF\u0448\u0456\u043D \u0436\u044B\u043B\u0434\u0430\u0440
    \u0431\u043E\u0439\u044B \u0434\u0430\u0439\u044B\u043D\u0434\u0430\u043B\u0443\u044B
    \u0431\u0456\u0437\u0434\u0456 \u043D\u0435\u0433\u0435 \u04AF\u0439\u0440\u0435\u0442\u0435\u0434\u0456? "
  _answers:
  - _info: "\u0410) \u041A\u0435\u0437 \u043A\u0435\u043B\u0433\u0435\u043D \u0456\u0441\u0442\u0456
      \u0442\u0435\u0437 \u0431\u0456\u0442\u0456\u0440\u0443\u0433\u0435. "
    _isCorrect: 0
  - _info: "\u018F) \u041C\u0430\u049B\u0441\u0430\u0442\u049B\u0430 \u0436\u0435\u0442\u0443
      \u0436\u043E\u043B\u044B\u043D\u0434\u0430\u0493\u044B \u0442\u0430\u0431\u0430\u043D\u0434\u044B\u043B\u044B\u049B
      \u043F\u0435\u043D \u0448\u044B\u0434\u0430\u043C\u0434\u044B\u043B\u044B\u049B\u049B\u0430. "
    _isCorrect: 1
  - _info: "\u0411) \u049A\u0438\u044B\u043D\u0434\u044B\u049B\u0442\u0430\u043D
      \u049B\u0430\u0448\u044B\u043F, \u0434\u0435\u043C\u0430\u043B\u0443\u0493\u0430. "
