  _info: "\u0411\u0430\u0442\u044B\u0440\u0434\u044B\u04A3 \u0421\u0430\u043C\u04B1\u0440\u044B\u049B
    \u0431\u0430\u043B\u0430\u043F\u0430\u043D\u0434\u0430\u0440\u044B\u043D \u0410\u0439\u0434\u0430\u04BB\u0430\u0440\u0434\u0430\u043D
