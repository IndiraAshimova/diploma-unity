  m_Script: {fileID: 11500000, guid: 12650b1558e7fc7409fcf331f13d287b, type: 3}
  m_Name: 3
  m_EditorClassIdentifier: 
  _info: "\u0410\u0439\u0434\u0430\u04BB\u0430\u0440\u0434\u044B\u04A3 \u0441\u043E\u04A3\u0493\u044B
    \u0441\u04E9\u0437\u0456\u043D\u0434\u0435\u0433\u0456 \xAB\u0410\u049B\u044B\u043B\u044B
    \u0430\u0441\u049B\u0430\u043D \u0430\u0434\u0430\u043C\u0434\u044B \u0436\u04B1\u0442\u0443
    \u2014 \u043C\u0430\u0493\u0430\u043D \u0430\u0440\u0430\u043C\xBB  \u0434\u0435\u0433\u0435\u043D
    \u0442\u0456\u0440\u043A\u0435\u0441\u0442\u0456\u04A3 \u0430\u0441\u0442\u0430\u0440\u044B
    \u043D\u0435?"
  _answers:
  - _info: "\u0416\u0435\u0440 \u0430\u0441\u0442\u044B \u0259\u043B\u0435\u043C\u0456\u043D\u0456\u04A3
      \u0437\u0430\u04A3\u044B \u0431\u043E\u0439\u044B\u043D\u0448\u0430, \u0430\u049B\u044B\u043B\u0434\u044B
      \u0436\u0435\u04A3\u0435 \u0430\u043B\u043C\u0430\u0493\u0430\u043D \u043C\u0430\u049B\u04B1\u043B\u044B\u049B
      \u04E9\u0437 \u0436\u0435\u04A3\u0456\u043B\u0456\u0441\u0456\u043D  \u043C\u043E\u0439\u044B\u043D\u0434\u0430\u0443\u0493\u0430
      \u043C\u0259\u0436\u0431\u04AF\u0440."
    _isCorrect: 1
  - _info: "\u0410\u0439\u0434\u0430\u04BB\u0430\u0440 \u0431\u0430\u0442\u044B\u0440\u0434\u044B\u04A3
      \u0435\u0442\u0456\u043D\u0435\u043D \u0436\u0438\u0456\u0440\u043A\u0435\u043D\u0434\u0456."
    _isCorrect: 0
  - _info: "\u0410\u0439\u0434\u0430\u04BB\u0430\u0440 \u0431\u0430\u0442\u044B\u0440\u043C\u0435\u043D
      \u0434\u043E\u0441 \u0431\u043E\u043B\u0493\u044B\u0441\u044B \u043A\u0435\u043B\u0434\u0456."
    _isCorrect: 0
  - _info: "\u0411\u0430\u0442\u044B\u0440\u0434\u044B\u04A3 \u049B\u0430\u043D\u044B
      \u0443\u043B\u044B \u0431\u043E\u043B\u044B\u043F \u043A\u04E9\u0440\u0456\u043D\u0434\u0456."
    _isCorrect: 0
  _useTimer: 0
  _timer: 0
