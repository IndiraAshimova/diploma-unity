  _info: "\u0410\u0439\u0434\u0430\u04BB\u0430\u0440 \u043D\u0435\u043B\u0456\u043A\u0442\u0435\u043D
    \u0415\u0440 \u0422\u04E9\u0441\u0442\u0456\u043A\u0442\u0456 \u0431\u0456\u0440\u0434\u0435\u043D
    \u0436\u04B1\u0442\u044B\u043F \u049B\u043E\u0439\u043C\u0430\u0439, \u043E\u0493\u0430\u043D
    \u0436\u04B1\u043C\u0431\u0430\u049B \u0436\u0430\u0441\u044B\u0440\u0443\u0434\u044B 
    \u04B1\u0439\u0493\u0430\u0440\u0434\u044B?"
  _answers:
  - _info: "\u0411\u0430\u0442\u044B\u0440\u0434\u044B\u04A3 \u049B\u0430\u0440\u0443\u044B\u043D\u0430\u043D
      \u049B\u043E\u0440\u044B\u049B\u049B\u0430\u043D\u0434\u044B\u049B\u0442\u0430\u043D."
    _isCorrect: 0
  - _info: "\u0415\u0440 \u0422\u04E9\u0441\u0442\u0456\u043A\u0442\u0456\u04A3 \u0440\u0443\u0445\u044B\u043D
      \u0441\u044B\u043D\u0434\u044B\u0440\u044B\u043F, \xAB\u0430\u0440\u0430\u043C
      \u0436\u0435\u043C\u0442\u0456\u043A\u043A\u0435\xBB \u0430\u0439\u043D\u0430\u043B\u0434\u044B\u0440\u0443
      \u04AF\u0448\u0456\u043D. "
    _isCorrect: 1
  - _info: "\u0410\u0439\u0434\u0430\u04BB\u0430\u0440\u0434\u044B\u04A3 \u04E9\u0437\u0456
      \u0436\u04B1\u043C\u0431\u0430\u049B \u0448\u0435\u0448\u043A\u0435\u043D\u0434\u0456
      \u0436\u0430\u049B\u0441\u044B \u043A\u04E9\u0440\u0433\u0435\u043D\u0434\u0456\u043A\u0442\u0435\u043D. "
    _isCorrect: 0
  - _info: "\u0411\u0259\u0439\u0442\u0435\u0440\u0435\u043A\u0442\u0456\u04A3 \u043A\u0438\u0435\u0441\u0456\u043D\u0435\u043D
      \u0441\u0435\u0441\u043A\u0435\u043D\u0433\u0435\u043D\u0434\u0456\u043A\u0442\u0435\u043D."
    _isCorrect: 0
